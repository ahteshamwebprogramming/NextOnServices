@model NextOnServices.Infrastructure.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/css/custmahte.css" rel="stylesheet" />
<link href="~/css/tooltip.css" rel="stylesheet" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />
<!-- vt-dashboard-ref.css above loads last among stylesheets so Figma styles win -->
<style>
    /* VT Dashboard theme: #1d7874 and shades only */
    :root {
        --vt-theme: #1d7874;
        --vt-theme-dark: #165c59;
        --vt-theme-darker: #124a47;
        --vt-theme-mid: #268d87;
        --vt-theme-light: #3ba29c;
        --vt-theme-lighter: #52b5af;
        --vt-theme-bg: rgba(29, 120, 116, 0.08);
        --vt-theme-border: rgba(29, 120, 116, 0.25);
        --vt-theme-text: #0f3d3b;
    }

    .vt-dashboard .bordertophighlight {
        border-top: 1px solid var(--vt-theme-border);
        box-shadow: 0 1px 8px rgba(29, 120, 116, 0.12);
        padding: 12px;
        border-radius: 8px;
        background: linear-gradient(180deg, #fff 0%, var(--vt-theme-bg) 100%);
    }

    .tooltip1 {
        border-bottom: 0px dotted black !important;
    }

    .vt-dashboard .container1_ppd {
        display: block;
        position: relative;
        padding-left: 0px;
        margin-bottom: 0px;
        cursor: pointer;
        font-size: 19px;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    .vt-dashboard .checkmark_ppd {
        position: absolute;
        top: 0px;
        left: 0;
        height: 20px;
        width: 20px;
        background-color: #eee;
    }

    .vt-dashboard .container1_ppd input:checked ~ .checkmark_ppd {
        background-color: var(--vt-theme);
    }

    .select2-container--default .select2-selection--single {
        padding: 0px;
    }

    span.select2-container--default {
        width: 100% !important;
    }

    .vt-dashboard .card-body .menu-icon img {
        width: 29px;
        margin-bottom: 12px;
        filter: brightness(0) invert(1);
    }

    .vt-dashboard .card-body { position: relative; }
    .vt-dashboard .card-body .bttmText {
        position: absolute;
        bottom: 10px;
        right: 16px;
        font-size: 14px;
    }

    .vt-dashboard .fs-30text {
        font-size: 40px !important;
        font-weight: 800;
        color: #fff !important;
    }

    /* Stat card text – force white so labels and numbers are visible on teal background */
    .vt-dashboard .dashboard-stat-cards .card .card-body,
    .vt-dashboard .dashboard-stat-cards .card .card-body p,
    .vt-dashboard .dashboard-stat-cards .card .card-body .menu-title,
    .vt-dashboard .dashboard-stat-cards .card .card-body .icons2,
    .vt-dashboard .dashboard-stat-cards .card .card-body .icons2 p {
        color: #fff !important;
        font-weight: 500;
    }

    /* Select2 – theme #1d7874 */
    .vt-dashboard select.dashboard-filter + span.select2 .select2-selection--single {
        border-radius: 12px;
        border: 1px solid var(--vt-theme-border);
        padding: 8px 44px 8px 18px;
        min-height: 44px;
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #ffffff 0%, var(--vt-theme-bg) 100%);
        box-shadow: 0 6px 16px rgba(29, 120, 116, 0.12);
        transition: all 0.2s ease-in-out;
    }

    .vt-dashboard select.dashboard-filter + span.select2 .select2-selection--single:hover,
    .vt-dashboard select.dashboard-filter + span.select2.select2-container--open .select2-selection--single,
    .vt-dashboard select.dashboard-filter + span.select2.select2-container--focus .select2-selection--single {
        border-color: var(--vt-theme);
        box-shadow: 0 8px 20px rgba(29, 120, 116, 0.2);
    }

    .vt-dashboard select.dashboard-filter + span.select2 .select2-selection__rendered {
        color: var(--vt-theme-text);
        font-weight: 600;
        letter-spacing: 0.3px;
        padding-left: 0;
    }

    .vt-dashboard select.dashboard-filter + span.select2 .select2-selection__placeholder {
        color: var(--vt-theme-mid);
        font-weight: 500;
    }

    .vt-dashboard select.dashboard-filter + span.select2 .select2-selection__arrow {
        height: 100%;
        width: 42px;
        background: linear-gradient(135deg, var(--vt-theme) 0%, var(--vt-theme-dark) 100%);
        border-radius: 0 11px 11px 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease-in-out;
    }

    .vt-dashboard select.dashboard-filter + span.select2 .select2-selection__arrow b {
        border-color: #fff transparent transparent transparent;
        border-width: 6px 5px 0 5px;
        margin-top: 0;
    }

    .vt-dashboard select.dashboard-filter + span.select2.select2-container--open .select2-selection__arrow {
        background: linear-gradient(135deg, var(--vt-theme-dark) 0%, var(--vt-theme-darker) 100%);
    }

    .vt-dashboard .select2-container--default .select2-dropdown,
    .select2-dropdown.vt-theme-dropdown {
        border: 1px solid var(--vt-theme-border);
        border-radius: 12px;
        box-shadow: 0 12px 28px rgba(29, 120, 116, 0.18);
        padding: 12px 0;
        overflow: hidden;
    }

    .vt-dashboard .select2-container--default .select2-results__option,
    .select2-dropdown.vt-theme-dropdown .select2-results__option {
        border-radius: 8px;
        margin: 4px 8px;
        padding: 12px 16px;
        font-weight: 500;
        color: var(--vt-theme-text);
        transition: background 0.15s ease, color 0.15s ease;
    }

    .vt-dashboard .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable,
    .select2-dropdown.vt-theme-dropdown .select2-results__option--highlighted.select2-results__option--selectable {
        background: linear-gradient(135deg, var(--vt-theme) 0%, var(--vt-theme-dark) 100%);
        color: #fff;
    }

    .vt-dashboard .select2-container--default .select2-results__option--selected,
    .select2-dropdown.vt-theme-dropdown .select2-results__option--selected {
        background: var(--vt-theme-bg);
        color: var(--vt-theme-dark);
        font-weight: 600;
    }

    .vt-dashboard .dataTables_filter input[type=search] {
        border-color: var(--vt-theme-border) !important;
        border-radius: 8px;
    }
    .vt-dashboard .dataTables_filter input[type=search]:focus {
        border-color: var(--vt-theme) !important;
        box-shadow: 0 0 0 2px rgba(29, 120, 116, 0.2);
    }

    /* Stat cards – theme shades only */
    .vt-dashboard .card.card-tale {
        background: linear-gradient(145deg, var(--vt-theme-dark) 0%, var(--vt-theme-darker) 100%) !important;
        color: #fff;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(29, 120, 116, 0.3);
    }

    .vt-dashboard .card.card-dark-blue {
        background: linear-gradient(145deg, var(--vt-theme) 0%, var(--vt-theme-dark) 100%) !important;
        color: #fff;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(29, 120, 116, 0.28);
    }

    .vt-dashboard .card.card-light-blue {
        background: linear-gradient(145deg, var(--vt-theme-mid) 0%, var(--vt-theme) 100%) !important;
        color: #fff;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(29, 120, 116, 0.25);
    }

    .vt-dashboard .card.card-light-danger {
        background: linear-gradient(145deg, var(--vt-theme-light) 0%, var(--vt-theme-mid) 100%) !important;
        color: #fff;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(29, 120, 116, 0.22);
    }

    .vt-dashboard .dashboard-stat-cards .card {
        height: 100%;
        min-height: 120px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .vt-dashboard .dashboard-stat-cards .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(29, 120, 116, 0.35);
    }
    .vt-dashboard .dashboard-stat-cards .card .card-body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 120px;
    }

    /* Project List card – theme accent */
    .vt-dashboard .card--table-section {
        border: 1px solid var(--vt-theme-border);
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(29, 120, 116, 0.08);
    }
    .vt-dashboard .table-section-header {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--vt-theme-dark) !important;
        border-bottom: 1px solid var(--vt-theme-border);
        border-left: 4px solid var(--vt-theme);
        background: linear-gradient(90deg, var(--vt-theme-bg) 0%, transparent 15%);
        border-radius: 0 6px 0 0;
    }

    /* Modal – theme (by id so it works when modal is moved to body) */
    #mdlChangeStatus .modal-header {
        border-bottom-color: var(--vt-theme-border);
        background: linear-gradient(180deg, var(--vt-theme-bg) 0%, #fff 100%);
    }
    #mdlChangeStatus .modal-title {
        color: var(--vt-theme-dark);
        font-weight: 600;
    }
    #mdlChangeStatus .modal-footer .btn-primary {
        background: linear-gradient(135deg, var(--vt-theme) 0%, var(--vt-theme-dark) 100%);
        border-color: var(--vt-theme-dark);
    }
    #mdlChangeStatus .modal-footer .btn-primary:hover {
        background: linear-gradient(135deg, var(--vt-theme-dark) 0%, var(--vt-theme-darker) 100%);
        border-color: var(--vt-theme-darker);
    }

    /* Table link to project – theme color */
    .vt-dashboard .table a[href*="ProjectPage"] {
        color: var(--vt-theme);
        font-weight: 600;
    }
    .vt-dashboard .table a[href*="ProjectPage"]:hover {
        color: var(--vt-theme-dark);
        text-decoration: underline;
    }
</style>


<div class="vt-dashboard vt-dashboard-ref ref-content-wrap">
    <!-- Page title (Figma/React style) -->
    <div class="ref-page-title">
        <h1>Dashboard</h1>
        <p class="ref-subtitle">Project overview and list</p>
    </div>

    <!-- Stats cards - label above number, no trend. data-stat used by Dashboard.js to update counts when Manager changes. -->
    <div class="ref-stats-row">
        <div class="ref-stat-card">
            <div>
                <div class="ref-stat-label">Total Projects</div>
                <div class="ref-stat-value" data-stat="total">@(Model?.ProjectCountSummary?.TotalProjects ?? 0)</div>
            </div>
            <div class="ref-stat-icon"><i class="mdi mdi-briefcase-outline" aria-hidden="true"></i></div>
        </div>
        <div class="ref-stat-card">
            <div>
                <div class="ref-stat-label">Active Projects</div>
                <div class="ref-stat-value" data-stat="active">@(Model?.ProjectCountSummary?.ActiveProjects ?? 0)</div>
            </div>
            <div class="ref-stat-icon"><i class="mdi mdi-play-circle-outline" aria-hidden="true"></i></div>
        </div>
        <div class="ref-stat-card">
            <div>
                <div class="ref-stat-label">Inactive Projects</div>
                <div class="ref-stat-value" data-stat="inactive">@(Model?.ProjectCountSummary?.InactiveProjects ?? 0)</div>
            </div>
            <div class="ref-stat-icon"><i class="mdi mdi-pause-circle-outline" aria-hidden="true"></i></div>
        </div>
        <div class="ref-stat-card">
            <div>
                <div class="ref-stat-label">Archived Projects</div>
                <div class="ref-stat-value" data-stat="archived">@(Model?.ProjectCountSummary?.ArchivedProjects ?? 0)</div>
            </div>
            <div class="ref-stat-icon"><i class="mdi mdi-archive" aria-hidden="true"></i></div>
        </div>
    </div>

    <!-- Project List card (Figma/React style) -->
    <div class="ref-project-card">
        <div class="ref-section-header">
            <div class="ref-section-bar"></div>
            <h2 class="ref-section-title">Project List</h2>
        </div>

        <!-- Filters row: PM, Status (teal), flags -->
        <div class="ref-filters-row" id="TableFilters">
            <div class="ref-filter-select-wrap">
                <select class="form-control form-control-sm dashboard-filter" name="Managers" onchange="getProjectTable()">
                    <option value="0">All</option>
                    @if (Model?.Managers != null)
                    {
                        foreach (var item in Model.Managers)
                        {
                            if (Model.CurrentUser?.UserId == item.UserId)
                            {
                                <option value="@item.UserId" selected="selected">@item.UserName</option>
                            }
                            else
                            {
                                <option value="@item.UserId">@item.UserName</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="ref-filter-select-wrap">
                <select class="form-control form-control-sm dashboard-filter" name="Status" onchange="getProjectTable()">
                    <option value="0">--Select--</option>
                    <option value="1">Closed</option>
                    <option value="2">Live</option>
                    <option value="3">On Hold</option>
                    <option value="4">Cancelled</option>
                    <option value="5">Awarded</option>
                    <option value="6">Invoiced</option>
                </select>
            </div>
            <div class="ref-flag-filters">
                <label class="tooltip1" title="IR Drop by 50%">
                    <input type="checkbox" id="chkBlue" onchange="getProjectTable()" />
                    <span class="mdi mdi-flag-variant ref-flag-icon" style="color: #2563eb"></span>
                </label>
                <label class="tooltip1" title="LOI Raised by 35%">
                    <input type="checkbox" id="chkYellow" onchange="getProjectTable()" />
                    <span class="mdi mdi-flag-variant ref-flag-icon" style="color: #eab308"></span>
                </label>
                <label class="tooltip1" title="IR drop by 50% and LOI Raised by 35%">
                    <input type="checkbox" id="chkRed" onchange="getProjectTable()" />
                    <span class="mdi mdi-flag-variant ref-flag-icon" style="color: #dc2626"></span>
                </label>
            </div>
        </div>

        <div class="table-responsive">
            <div id="div_ProjectTable">
                @Html.Partial("_Dashboard/_ProjectTable.cshtml")
            </div>
        </div>
    </div>
</div>

<div class="modals">
    <div class="modal fade" id="mdlChangeStatus" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLongTitle">Change Projects Status</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12">
                            <select id="mdlChangeStatusSelect" class="form-control form-control-sm" name="Status">
                                <option value="1">Closed</option>
                                <option value="2">Live</option>
                                <option value="3">On Hold</option>
                                <option value="4">Cancelled</option>
                                <option value="5">Awarded</option>
                                <option value="6">Invoiced</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" id="mdlChangeStatusProjectId" value="0" name="ProjectId" />
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="UpdateStatus()">Update Status</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/customJS/Home/Dashboard.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            initVtDashboardFilterSelects();
            $('select').not('#TableFilters select.dashboard-filter').select2({
                dropdownCssClass: 'vt-theme-dropdown'
            });
            getProjectTable();
        });

        function getProjectTable() {
            BlockUI();
            getProjectTablePartialView().then((d) => {
                UnblockUI();
            });
        }

    </script>
}
