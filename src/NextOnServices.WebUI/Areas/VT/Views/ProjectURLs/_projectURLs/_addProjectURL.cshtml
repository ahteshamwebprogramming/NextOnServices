@model NextOnServices.Infrastructure.ViewModels.ProjectsURL.ProjectsURLViewModel
<div class="col-md-12 grid-margin stretch-card">
    <div class="card card--table-section">
        <div class="card-body">
            <h4 class="table-section-header">URL Mapping</h4>
            <p class="card-description mb-3">
                @if (Model?.Project != null)
                {
                    <span>Project: <strong>@Model.Project.Pid</strong> - @Model.Project.Pname</span>
                }
                else
                {
                    <span>Add or edit URL mappings for the selected project.</span>
                }
            </p>

            <form class="forms-sample vt-add-project-form" id="ProjectURLForm">
                <div class="row">
                    <div class="form-group col-md-12 mb-2">
                        <div class="vt-token-toggle-wrap">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkTokens" asp-for="ProjectsURL.TokenBool" onchange="Tokens(this.id)" />
                                <label class="form-check-label" for="chkTokens">Use tokens for this URL</label>
                            </div>
                            <p class="vt-token-help">Enable this when each respondent should have an assigned token.</p>
                        </div>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="CountryId">Country</label>
                        <select class="form-control form-control-sm select2" asp-for="ProjectsURL.Cid" id="CountryId">
                            <option value="0">--Select Country--</option>
                            @if (Model?.Countries != null && Model.Countries.Count > 0)
                            {
                                foreach (var item in Model.Countries)
                                {
                                    <option value="@item.CountryId">@item.Country</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="Url">URL</label>
                        <input type="url" class="form-control form-control-sm" asp-for="ProjectsURL.Url" id="Url" placeholder="https://example.com/survey">
                        <p class="help-block WOT vt-url-field-note mt-1 mb-0">Without token: https://www.abcdefgh.aspx?RIS=20&amp;RID=[respondentID]</p>
                        <p class="help-block WT vt-url-field-note mt-1 mb-0" style="display:none">With token: https://www.abcdefgh.aspx?RIS=20&amp;RID=[respondentID]&amp;TID=[TokenID]</p>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="RespondentQuota">Respondent Quota</label>
                        <input type="number" class="form-control form-control-sm" asp-for="ProjectsURL.Quota" id="RespondentQuota">
                    </div>

                    <div class="form-group col-md-4">
                        <label for="Cpi">CPI ($)</label>
                        <input type="number" class="form-control form-control-sm" asp-for="ProjectsURL.Cpi" id="Cpi" step="0.01">
                    </div>

                    <div class="form-group col-md-8">
                        <label for="Notes">Notes</label>
                        <textarea class="form-control form-control-sm" asp-for="ProjectsURL.Notes" id="Notes" rows="2" placeholder="Optional notes for operations team"></textarea>
                    </div>

                    <div class="form-group col-md-12 WT">
                        <label for="TokenRaw">Paste tokens below</label>
                        <textarea rows="5" class="form-control form-control-sm" asp-for="ProjectsURL.TokenRaw" id="TokenRaw" placeholder="One token per line"></textarea>
                    </div>
                </div>

                <input type="hidden" asp-for="ProjectsURL.Id" />

                <div class="mt-3">
                    <button type="button" class="btn btn-primary btn-sm" onclick="AddURL()">@((Model?.ProjectsURL?.Id ?? 0) > 0 ? "Update URL" : "Save URL")</button>
                    <button type="button" class="btn btn-light btn-sm" onclick="window.location.href = document.referrer || '/VT/Projects/ProjectsList'">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
