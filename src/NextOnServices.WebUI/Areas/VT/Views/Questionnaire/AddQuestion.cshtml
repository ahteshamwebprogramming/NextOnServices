@using NextOnServices.Infrastructure.Helper;
@model NextOnServices.Infrastructure.ViewModels.Questionnaire.AddQuestionnaire

@{
    ViewData["Title"] = "Add Question";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />

<style>
    .select2-container--default .select2-selection--single {
        padding: 0.5rem 0.81rem;
    }

    .select2-container .select2-selection--single {
        height: 2.575rem;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 38px;
    }

    .option-item {
        border: 1px solid #ddd;
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 4px;
        background-color: #f9f9f9;
    }

    .option-item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }
</style>

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card card--table-section">
            <div class="card-body">
                <h4 class="table-section-header">Question</h4>
                <p class="card-description mb-0">Please fill in the details below</p>
                <form class="forms-sample" id="QuestionForm">
                    <input type="hidden" id="Id" name="Id" value="@(Model?.Question?.Id ?? 0)">
                    
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="QuestionId">Question ID <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-sm" id="QuestionId" name="QuestionId" 
                                   value="@(Model?.Question?.QuestionId ?? "")" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="QuestionType">Question Type <span class="text-danger">*</span></label>
                            <select class="form-control form-control-sm" id="QuestionType" name="QuestionType" required>
                                <option value="">--Select Type--</option>
                                @if (Model?.Question?.QuestionType == 1)
                                {
                                    <option value="1" selected>Single Choice</option>
                                }
                                else
                                {
                                    <option value="1">Single Choice</option>
                                }
                                @if (Model?.Question?.QuestionType == 2)
                                {
                                    <option value="2" selected>Multiple Choice</option>
                                }
                                else
                                {
                                    <option value="2">Multiple Choice</option>
                                }
                                @if (Model?.Question?.QuestionType == 3)
                                {
                                    <option value="3" selected>Text Input</option>
                                }
                                else
                                {
                                    <option value="3">Text Input</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group col-md-12">
                            <label for="QuestionLabel">Question Label <span class="text-danger">*</span></label>
                            <textarea class="form-control form-control-sm" id="QuestionLabel" name="QuestionLabel" rows="3" required>@(Model?.Question?.QuestionLabel ?? "")</textarea>
                        </div>
                    </div>

                    <div class="row" id="optionsSection" style="display: @(Model?.Question?.QuestionType == 3 ? "none" : "block");">
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5>Options</h5>
                                <button type="button" class="btn btn-sm btn-primary" id="addOptionBtn">Add Option</button>
                            </div>
                            <div id="optionsContainer">
                                @if (Model?.Question?.Options != null && Model.Question.Options.Any())
                                {
                                    foreach (var option in Model.Question.Options)
                                    {
                                        <div class="option-item" data-option-id="@option.Id">
                                            <div class="option-item-header">
                                                <strong>Option @(Model.Question.Options.IndexOf(option) + 1)</strong>
                                                <button type="button" class="btn btn-sm btn-danger remove-option">Remove</button>
                                            </div>
                                            <div class="row">
                                                <div class="form-group col-md-4">
                                                    <label>Option Label</label>
                                                    <input type="text" class="form-control form-control-sm option-label" 
                                                           value="@option.OptionLabel" required>
                                                </div>
                                                <div class="form-group col-md-4">
                                                    <label>Option Code</label>
                                                    <input type="text" class="form-control form-control-sm option-code" 
                                                           value="@option.OptionCode">
                                                </div>
                                                <div class="form-group col-md-4">
                                                    <label>Option Number</label>
                                                    <input type="number" class="form-control form-control-sm option-number" 
                                                           value="@(option.OptionNumber ?? 0)">
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-12">
                            <button type="submit" class="btn btn-primary mr-2">Save</button>
                            <a href="/VT/Questionnaire/QuestionsList" class="btn btn-light">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let optionCounter = @(Model?.Question?.Options?.Count ?? 0);

            // Show/hide options based on question type
            $('#QuestionType').change(function () {
                if ($(this).val() == '3') {
                    $('#optionsSection').hide();
                } else {
                    $('#optionsSection').show();
                }
            });

            // Add option
            $('#addOptionBtn').click(function () {
                optionCounter++;
                const optionHtml = `
                    <div class="option-item" data-option-id="0">
                        <div class="option-item-header">
                            <strong>Option ${optionCounter}</strong>
                            <button type="button" class="btn btn-sm btn-danger remove-option">Remove</button>
                        </div>
                        <div class="row">
                            <div class="form-group col-md-4">
                                <label>Option Label</label>
                                <input type="text" class="form-control form-control-sm option-label" required>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Option Code</label>
                                <input type="text" class="form-control form-control-sm option-code">
                            </div>
                            <div class="form-group col-md-4">
                                <label>Option Number</label>
                                <input type="number" class="form-control form-control-sm option-number" value="${optionCounter}">
                            </div>
                        </div>
                    </div>
                `;
                $('#optionsContainer').append(optionHtml);
            });

            // Remove option
            $(document).on('click', '.remove-option', function () {
                $(this).closest('.option-item').remove();
            });

            // Form submit
            $('#QuestionForm').submit(function (e) {
                e.preventDefault();

                if (!$(this)[0].checkValidity()) {
                    $(this)[0].reportValidity();
                    return;
                }

                const questionData = {
                    Id: parseInt($('#Id').val()) || 0,
                    QuestionId: $('#QuestionId').val(),
                    QuestionLabel: $('#QuestionLabel').val(),
                    QuestionType: parseInt($('#QuestionType').val()),
                    Options: []
                };

                // Collect options
                if ($('#QuestionType').val() != '3') {
                    $('#optionsContainer .option-item').each(function (index) {
                        const option = {
                            Id: parseInt($(this).data('option-id')) || 0,
                            OptionLabel: $(this).find('.option-label').val(),
                            OptionCode: $(this).find('.option-code').val(),
                            OptionNumber: parseInt($(this).find('.option-number').val()) || (index + 1)
                        };
                        if (option.OptionLabel) {
                            questionData.Options.push(option);
                        }
                    });
                }

                $.ajax({
                    url: '/VT/Questionnaire/ManageQuestion',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(questionData),
                    success: function (response) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response,
                            showConfirmButton: true
                        }).then(function () {
                            window.location.href = '/VT/Questionnaire/QuestionsList';
                        });
                    },
                    error: function (xhr) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: xhr.responseText || 'An error occurred'
                        });
                    }
                });
            });
        });
    </script>
}

