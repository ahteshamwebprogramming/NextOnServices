@model NextOnServices.VT.Infrastructure.ViewModels.Supplier.SupplierViewModel
@{
    ViewData["Title"] = "Add Supplier";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/CustmAhte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/validation.css" rel="stylesheet" asp-append-version="true" />
<style>
    .vt-add-supplier-page {
        --vt-supplier-theme: #1d7874;
        --vt-supplier-theme-dark: #165c59;
        --vt-supplier-border: rgba(29, 120, 116, 0.22);
        --vt-supplier-soft: rgba(29, 120, 116, 0.08);
    }

    .vt-add-supplier-page .ref-page-title {
        margin-bottom: 1rem;
    }

    .vt-add-supplier-page .ref-page-title h1 {
        margin-bottom: 0.2rem;
    }

    .vt-add-supplier-page .card--table-section {
        border: 1px solid var(--vt-supplier-border);
        box-shadow: 0 6px 16px rgba(29, 120, 116, 0.08);
    }

    .vt-add-supplier-page .table-section-header {
        border-left-color: var(--vt-supplier-theme);
    }

    .vt-add-supplier-page .vt-form-section {
        margin-bottom: 0.9rem;
        padding: 0.45rem 0.75rem;
        border: 1px solid var(--vt-supplier-border);
        border-radius: 8px;
        background: linear-gradient(135deg, #fff 0%, var(--vt-supplier-soft) 100%);
        color: #0f3d3b;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .vt-add-supplier-page .form-group {
        margin-bottom: 0.95rem;
    }

    .vt-add-supplier-page .form-control,
    .vt-add-supplier-page input.form-control:not([type="checkbox"]),
    .vt-add-supplier-page select.form-control,
    .vt-add-supplier-page textarea.form-control {
        font-size: 0.875rem;
        height: 38px;
        min-height: 38px;
        border: 1px solid #dbe3ea;
        border-radius: 8px;
    }

    .vt-add-supplier-page textarea.form-control {
        height: auto;
        min-height: 96px;
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
    }

    .vt-add-supplier-page .form-control:focus {
        border-color: var(--vt-supplier-theme);
        outline: none;
        box-shadow: 0 0 0 2px rgba(29, 120, 116, 0.2);
    }

    .vt-add-supplier-page .help-block {
        font-size: 0.78rem;
        margin-top: 0.3rem;
        color: #64748b !important;
    }

    .vt-add-supplier-page .select2-container {
        width: 100% !important;
    }

    .vt-add-supplier-page .select2-container--default .select2-selection--single {
        height: 38px !important;
        min-height: 38px !important;
        border: 1px solid #dbe3ea !important;
        border-radius: 8px !important;
        padding: 0 2.1rem 0 0.75rem !important;
        display: flex !important;
        align-items: center !important;
    }

    .vt-add-supplier-page .select2-container--default .select2-selection--single .select2-selection__rendered {
        height: 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        line-height: 1.2 !important;
        display: inline-flex !important;
        align-items: center !important;
        color: #1f2937 !important;
    }

    .vt-add-supplier-page .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 100% !important;
        width: 1.75rem !important;
        right: 0.45rem !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
    }

    .vt-add-supplier-page .select2-container--default .select2-selection--single .select2-selection__arrow b {
        margin-top: 0 !important;
    }

    .vt-add-supplier-page .btn-primary {
        background: linear-gradient(135deg, var(--vt-supplier-theme) 0%, var(--vt-supplier-theme-dark) 100%) !important;
        border-color: var(--vt-supplier-theme-dark) !important;
        color: #fff !important;
    }

    .vt-add-supplier-page .btn-primary:hover {
        background: linear-gradient(135deg, var(--vt-supplier-theme-dark) 0%, #124a47 100%) !important;
        border-color: #124a47 !important;
    }

    .vt-add-supplier-page .btn-light {
        border: 1px solid #dbe3ea !important;
        color: #1f2937;
        background: #fff;
    }

    .vt-add-supplier-page .btn-light:hover {
        background: #f8fafc;
    }

    .vt-add-supplier-page .required::after {
        content: " *";
        color: #dc2626;
        font-weight: 700;
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-add-supplier-page">
    <div class="ref-page-title">
        <h1>Add Supplier</h1>
        <p class="ref-subtitle">Create or update supplier details and endpoint mappings</p>
    </div>

    <div class="row">
        <div class="col-md-12 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <h4 class="table-section-header">Supplier</h4>
                    <p class="card-description mb-3">Please fill in the details below.</p>

                    <form class="forms-sample vt-add-project-form" id="SupplierForm">
                        <div class="vt-form-section">Basic Details</div>
                        <div class="row">
                            <div class="form-group col-md-4">
                                <label for="Supplier_Name" class="required">Supplier Name</label>
                                <input type="text" class="form-control requiredInput" id="Supplier_Name" asp-for="Supplier.Name">
                            </div>
                            <div class="form-group col-md-4">
                                <label for="Supplier_Description" class="required">Supplier Description</label>
                                <input type="text" class="form-control requiredInput" id="Supplier_Description" asp-for="Supplier.Description">
                            </div>
                            <div class="form-group col-md-4">
                                <label for="Supplier_Number" class="required">Contact Number</label>
                                <input type="number" class="form-control requiredInput" id="Supplier_Number" placeholder="00 999 9999" asp-for="Supplier.Number">
                            </div>
                            <div class="form-group col-md-4">
                                <label for="Supplier_Email" class="required">Email</label>
                                <input type="email" class="form-control requiredInput" id="Supplier_Email" asp-for="Supplier.Email">
                            </div>
                            <div class="form-group col-md-4">
                                <label for="Supplier_Psize" class="required">Panel Size</label>
                                <input type="number" class="form-control requiredInput" id="Supplier_Psize" asp-for="Supplier.Psize">
                            </div>
                            <div class="form-group col-md-4">
                                <label for="Supplier_Country" class="required">Country</label>
                                <select class="form-control requiredInput select2" id="Supplier_Country" asp-for="Supplier.Country">
                                    <option value="0">--Select Country--</option>
                                    @if (Model?.Countries != null)
                                    {
                                        foreach (var item in Model.Countries)
                                        {
                                            <option value="@item.Country">@item.Country</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="vt-form-section mt-2">Endpoints</div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label for="Supplier_Completes">Completes</label>
                                <input type="url" class="form-control" id="Supplier_Completes" asp-for="Supplier.Completes">
                                <p class="help-block">https://www.abcdefgh.aspx?RIS=20&amp;RID=[respondentID]</p>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_Terminate">Terminate</label>
                                <input type="url" class="form-control" id="Supplier_Terminate" asp-for="Supplier.Terminate">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_Overquota">Overquota</label>
                                <input type="url" class="form-control" id="Supplier_Overquota" asp-for="Supplier.Overquota">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_Security">Security Term</label>
                                <input type="url" class="form-control" id="Supplier_Security" asp-for="Supplier.Security">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_Fraud">Fraud Error</label>
                                <input type="url" class="form-control" id="Supplier_Fraud" asp-for="Supplier.Fraud">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_Success">Success</label>
                                <input type="url" class="form-control" id="Supplier_Success" asp-for="Supplier.Success">
                            </div>
                        </div>

                        <div class="vt-form-section mt-2">Response Templates and Notes</div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label for="Supplier_Default">Default</label>
                                <textarea asp-for="Supplier.Default" class="form-control" id="Supplier_Default"></textarea>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_Failure">Failure</label>
                                <textarea asp-for="Supplier.Failure" class="form-control" id="Supplier_Failure"></textarea>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_QualityTermination">Quality Termination</label>
                                <textarea asp-for="Supplier.QualityTermination" class="form-control" id="Supplier_QualityTermination"></textarea>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="Supplier_OverQuota1">Over Quota</label>
                                <textarea asp-for="Supplier.OverQuota1" class="form-control" id="Supplier_OverQuota1"></textarea>
                            </div>
                            <div class="form-group col-md-12">
                                <label for="Supplier_Notes">Notes</label>
                                <textarea asp-for="Supplier.Notes" class="form-control" id="Supplier_Notes" placeholder="Enter your notes here"></textarea>
                            </div>
                        </div>

                        <input type="hidden" asp-for="Supplier.Id" />
                        <div class="mt-3">
                            <button type="button" class="btn btn-primary mr-2 btn-sm" onclick="AddSupplier()">@((Model?.Supplier?.Id ?? 0) > 0 ? "Update Supplier" : "Save Supplier")</button>
                            <button type="button" class="btn btn-light btn-sm" onclick="window.location.href = document.referrer || '/VT/Supplier/SupplierList'">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/customJS/Validation.js" asp-append-version="true"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(".select2").select2({
                dropdownCssClass: 'vt-theme-dropdown',
                width: '100%'
            });
        });

        function AddSupplier() {
            if (!isValidateForm("SupplierForm")) {
                return false;
            }

            var supplierData = $("#SupplierForm");
            var inputDTO = {};
            inputDTO.Id = isNaN($(supplierData).find("[name='Supplier.Id']").val()) ? 0 : $.trim($(supplierData).find("[name='Supplier.Id']").val()) === "" ? 0 : $(supplierData).find("[name='Supplier.Id']").val();
            inputDTO.Name = $(supplierData).find("[name='Supplier.Name']").val();
            inputDTO.Description = $(supplierData).find("[name='Supplier.Description']").val();
            inputDTO.Number = $(supplierData).find("[name='Supplier.Number']").val();
            inputDTO.Email = $(supplierData).find("[name='Supplier.Email']").val();
            inputDTO.Psize = $(supplierData).find("[name='Supplier.Psize']").val();
            inputDTO.Country = $(supplierData).find("[name='Supplier.Country']").val();
            inputDTO.Completes = $(supplierData).find("[name='Supplier.Completes']").val();
            inputDTO.Terminate = $(supplierData).find("[name='Supplier.Terminate']").val();
            inputDTO.Overquota = $(supplierData).find("[name='Supplier.Overquota']").val();
            inputDTO.Security = $(supplierData).find("[name='Supplier.Security']").val();
            inputDTO.Fraud = $(supplierData).find("[name='Supplier.Fraud']").val();
            inputDTO.Success = $(supplierData).find("[name='Supplier.Success']").val();
            inputDTO.Default = $(supplierData).find("[name='Supplier.Default']").val();
            inputDTO.Failure = $(supplierData).find("[name='Supplier.Failure']").val();
            inputDTO.QualityTermination = $(supplierData).find("[name='Supplier.QualityTermination']").val();
            inputDTO.OverQuota1 = $(supplierData).find("[name='Supplier.OverQuota1']").val();
            inputDTO.Notes = $(supplierData).find("[name='Supplier.Notes']").val();

            BlockUI();

            $.ajax({
                type: "POST",
                url: "/VT/Supplier/ManageSupplier",
                contentType: 'application/json',
                data: JSON.stringify(inputDTO),
                success: function (data) {
                    UnblockUI();
                    var successMessage = inputDTO.Id > 0 ? "Supplier updated successfully." : "Supplier added successfully.";
                    Swal.fire({ title: 'Success', text: successMessage, icon: 'success', confirmButtonText: 'OK' }).then(function (result) {
                        if (result.isConfirmed) {
                            if (inputDTO.Id > 0) {
                                window.location.href = "/VT/Supplier/SupplierList";
                            }
                            else {
                                window.location.href = "/VT/Supplier/SupplierCountryPanelSize/" + data.encId;
                            }
                        }
                    });
                },
                error: function (error) {
                    UnblockUI();
                    $erroralert("Error!", error.responseText);
                }
            });
        }
    </script>
}
