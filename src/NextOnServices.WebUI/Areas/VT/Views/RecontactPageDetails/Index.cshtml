@{
    ViewData["Title"] = "Recontact Details";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/CustmAhte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<style>
    .recontact-details-page.vt-project-page { font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif; font-size: 14px; color: #0f172a; }
    .recontact-details-page .table-section-header { font-size: 1rem !important; font-weight: 600 !important; }
    .recontact-details-page .header { font-weight: 600; font-size: 0.9375rem; }
    .recontact-details-page .bordertophighlight { border-top: 1px solid #f1f1f1; box-shadow: 0 1px 4px 1px #f1f1f1; padding: 12px; }
    .recontact-details-page .form-control, .recontact-details-page input.form-control, .recontact-details-page textarea.form-control { font-size: 0.875rem; height: 36px; min-height: 36px; border: 1px solid #dbe3ea; border-radius: 8px; }
    .recontact-details-page textarea.form-control { min-height: 80px; }
    .recontact-details-page .form-control:focus { border-color: #0f7f79; box-shadow: 0 0 0 2px rgba(15, 127, 121, 0.2); }
    .recontact-details-page .btn-primary { background: #0f7f79 !important; border-color: #0f7f79 !important; }
    .recontact-details-page .btn-primary:hover { background: #0d6b66 !important; border-color: #0d6b66 !important; }
    .recontact-details-page .redirect-link-value { width: 100%; min-height: 38px; word-break: break-all; box-sizing: border-box; }
</style>
<input type="hidden" id="hfRecontactId" value="@(ViewData["RecontactId"] ?? 0)" />

<div class="recontact-details-page vt-project-page">
<!-- Edit modal -->
<div class="modal fade" id="modal_EditRecontactProject" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal_h4__cpi">Edit Recontact Project</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hfId" />
                <p class="small text-muted mb-2"><span id="lblPname">Recontact Project</span> — <span id="lnlPnumber">NXT0001</span></p>
                <div class="form-group">
                    <label class="control-label" for="txtRecontactDescription">Recontact Description</label>
                    <input type="text" class="form-control" id="txtRecontactDescription" placeholder="Recontact Description" />
                </div>
                <div class="form-group">
                    <label class="control-label" for="txtLOI">LOI</label>
                    <input type="text" class="form-control" id="txtLOI" placeholder="LOI" />
                </div>
                <div class="form-group">
                    <label class="control-label" for="txtIR">Incident Rate (%)</label>
                    <input type="text" class="form-control" id="txtIR" placeholder="Incident Rate" />
                </div>
                <div class="form-group">
                    <label class="control-label" for="txtCPI">CPI</label>
                    <input type="text" class="form-control" id="txtCPI" placeholder="CPI" />
                </div>
                <div class="form-group">
                    <label class="control-label" for="txtRCQ">Respondent Quota</label>
                    <input type="text" class="form-control" id="txtRCQ" placeholder="Respondent Quota" />
                </div>
                <div class="form-group">
                    <label class="control-label" for="txtNOTES">Notes</label>
                    <textarea class="form-control" id="txtNOTES" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="SaveRecontactDetails()">Save changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Survey details & KPIs -->
<div class="row">
    <div class="col-12 grid-margin">
        <div class="card card--table-section">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <p class="table-section-header mb-0">Survey Details</p>
                    <button type="button" class="btn btn-primary btn-sm" onclick="GetRecontactProjectDetails()">Edit</button>
                </div>
                <div class="row mt-3">
                    <div class="col-md-7">
                        <table class="table table-hover table-bordered">
                            <tbody>
                                <tr>
                                    <td class="header w-30">Survey ID</td>
                                    <td><span id="lblSurveyID"></span><input type="hidden" id="hflblSurveyID" /></td>
                                </tr>
                                <tr>
                                    <td class="header">Survey Name</td>
                                    <td><span id="lblSurvayname"></span><input type="hidden" id="hflblSurvayname" /></td>
                                </tr>
                                <tr>
                                    <td class="header">Length of Interview</td>
                                    <td><span id="lblLOI">Yet to Come</span> min</td>
                                </tr>
                                <tr>
                                    <td class="header">CPI</td>
                                    <td>$ <span id="lblCPI">Yet to Come</span></td>
                                </tr>
                                <tr>
                                    <td class="header">Expected IR</td>
                                    <td><span id="txtEIR">Yet to Come</span></td>
                                </tr>
                                <tr>
                                    <td class="header">Notes</td>
                                    <td><span id="lblNotes"></span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-5 pt-4 recontact-kpi-col">
                        <p id="hstatus" class="mb-1 small text-muted text-center">Status</p>
                        <p class="mb-3 text-center" style="color: #0f7f79; font-weight: 700; font-size: 1.75rem;">
                            <span id="lblCompletion">0</span>% <span class="small font-weight-normal text-success">Achieved</span>
                        </p>
                        <div class="recontact-kpi-row">
                            <div class="bordertophighlight recontact-kpi-item">
                                <div class="small text-muted">Completed</div>
                                <span id="spncompletes" style="font-size: 1.25rem; color: #0f7f79; font-weight: 700">0</span>
                                <span class="small text-muted"> out of </span>
                                <span id="spnTotalcomplete" style="font-size: 1.25rem; color: #0f7f79; font-weight: 700">0</span>
                            </div>
                            <div class="bordertophighlight recontact-kpi-item">
                                <div class="small text-muted">Actual IR</div>
                                <span id="spnpercentIR" style="font-size: 1.25rem; color: #0f7f79; font-weight: 700">0</span> %
                            </div>
                            <div class="bordertophighlight recontact-kpi-item">
                                <div class="small text-muted">Actual LOI</div>
                                <span id="spnLOI" style="font-size: 1.25rem; color: #0f7f79; font-weight: 700">0</span> min
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Country details -->
<div class="row">
    <div class="col-12 grid-margin">
        <div class="card card--table-section">
            <div class="card-body">
                <p class="table-section-header">Country Details</p>
                <div class="table-responsive">
                    <table id="tblCountry" class="table table-hover table-bordered">
                        <thead>
                            <tr>
                                <th>Country</th>
                                <th>Total</th>
                                <th>Complete</th>
                                <th>Terminate</th>
                                <th>Overquota</th>
                                <th>Security Term</th>
                                <th>Fraud Error</th>
                                <th>Incomplete</th>
                                <th>Cancelled</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Supplier details -->
<div class="row">
    <div class="col-12 grid-margin">
        <div class="card card--table-section">
            <div class="card-body">
                <p class="table-section-header">Supplier Details</p>
                <div class="table-responsive">
                    <table id="tblSupplierDetails" class="table table-hover table-bordered">
                        <thead>
                            <tr>
                                <th style="display:none">ID</th>
                                <th>Supplier Name</th>
                                <th>Total</th>
                                <th>Complete</th>
                                <th>Terminate</th>
                                <th>Overquota</th>
                                <th>Security Term</th>
                                <th>Fraud Error</th>
                                <th>Incomplete</th>
                                <th>Cancelled</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Redirect links -->
<div class="row">
    <div class="col-12 grid-margin">
        <div class="card card--table-section">
            <div class="card-body">
                <p class="table-section-header">Redirect Links</p>
                <div class="row">
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Completes</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblComplete"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Terminate</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblTerminate"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Overquota</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblOverquota"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Security Term</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblS_Term"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Fraud Error</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblF_Error"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Variable 1</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblVar1"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="control-label">Variable 2</label>
                            <div class="form-control-plaintext form-control-sm border rounded px-2 py-1 bg-light redirect-link-value" id="lblVar2"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section scripts {
    <script>
        (function () {
            function getquerystringid() {
                var qs = new URLSearchParams(window.location.search);
                var id = qs.get('Id') || qs.get('ID');
                if (!id || isNaN(parseInt(id, 10))) {
                    var fallback = document.getElementById('hfRecontactId');
                    if (fallback && fallback.value) {
                        id = fallback.value;
                    }
                }
                return id;
            }

            function LoadTable(id, opt) {
                $.ajax({
                    type: 'POST',
                    url: '/VT/RecontactPageDetails/FetchRecontactProjects',
                    contentType: 'application/json; charset=utf-8',
                    data: JSON.stringify({ Id: parseInt(id, 10), Opt: opt }),
                    success: function (response) {
                        var data = response && response.d ? response.d : response || [];

                        var countrydata = data[0] || [];
                        var tbodycountry = '';
                        $('#tblCountry tbody').empty();
                        for (var i = 0; i < countrydata.length; i++) {
                            var c = countrydata[i];
                            var countryName = c.countryname ?? c.countryName ?? c.Countryname ?? '';
                            tbodycountry += '<tr><td>' + (countryName || '') + '</td><td>' + (c.total ?? '') + '</td><td>' + (c.complete ?? '') + '</td><td>' + (c.terminate ?? '') + '</td><td>' + (c.overquota ?? '') + '</td><td>' + (c.s_term ?? '') + '</td><td>' + (c.f_error ?? '') + '</td><td>' + (c.incomplete ?? '') + '</td><td>' + (c.cancelled ?? '') + '</td></tr>';
                        }
                        if (tbodycountry) {
                            $('#tblCountry tbody').html(tbodycountry);
                        }

                        var supplierdata = data[1] || [];
                        var tbodysupp = '';
                        $('#tblSupplierDetails tbody').empty();
                        for (var j = 0; j < supplierdata.length; j++) {
                            var s = supplierdata[j];
                            var supplierName = s.suppliername ?? s.supplierName ?? s.Suppliername ?? '';
                            tbodysupp += '<tr><td style="display:none">' + (s.id ?? '') + '</td><td>' + (supplierName || '') + '</td><td>' + (s.total ?? '') + '</td><td>' + (s.complete ?? '') + '</td><td>' + (s.terminate ?? '') + '</td><td>' + (s.overquota ?? '') + '</td><td>' + (s.s_term ?? '') + '</td><td>' + (s.f_error ?? '') + '</td><td>' + (s.incomplete ?? '') + '</td><td>' + (s.cancelled ?? '') + '</td></tr>';
                        }
                        if (tbodysupp) {
                            $('#tblSupplierDetails tbody').html(tbodysupp);
                        }

                        var redirects = data[2] || [];
                        if (redirects.length > 0) {
                            var r = redirects[0];
                            $('#lblComplete').text(r.complete ?? r.Complete ?? '');
                            $('#lblTerminate').text(r.terminate ?? r.Terminate ?? '');
                            $('#lblOverquota').text(r.overquota ?? r.Overquota ?? '');
                            $('#lblS_Term').text(r.s_Term ?? r.S_Term ?? '');
                            $('#lblF_Error').text(r.f_Error ?? r.F_Error ?? '');
                            $('#lblVar1').text(r.variable1 ?? r.Variable1 ?? '');
                            $('#lblVar2').text(r.variable2 ?? r.Variable2 ?? '');
                        }

                        var remainingdetails = data[3] || [];
                        if (remainingdetails.length > 0) {
                            var d = remainingdetails[0];
                            var projectNumber = d.projectNumber ?? d.ProjectNumber ?? '';
                            var rProjectName = d.rProjectName ?? d.RProjectName ?? '';
                            var notes = d.notes ?? d.Notes ?? '';
                            var status = d.status ?? d.Status ?? '';
                            $('#lblSurveyID').text(projectNumber);
                            $('#hflblSurveyID').val(projectNumber);
                            $('#lblSurvayname').text(rProjectName);
                            $('#hflblSurvayname').val(rProjectName);
                            $('#lblLOI').text(d.loi ?? d.LOI ?? '');
                            $('#lblCPI').text(d.cpi ?? d.CPI ?? '');
                            $('#txtEIR').text(d.ir ?? d.IR ?? '');
                            $('#hstatus').text(status);
                            $('#lblNotes').text(notes);
                        }

                        // KPI block from RecontactParametersCalC (same as NextOnServices_Old GetRecontactParametersCalc)
                        var kpi = data[4];
                        if (kpi && (kpi.complete !== undefined || kpi.total !== undefined || kpi.status !== undefined)) {
                            $('#hstatus').text(kpi.status ?? kpi.Status ?? '');
                            var complete = parseInt(kpi.complete ?? kpi.Complete ?? 0, 10);
                            var total = parseInt(kpi.total ?? kpi.Total ?? 0, 10);
                            var achievedPct = total > 0 ? Math.round(100 * complete / total) : 0;
                            $('#lblCompletion').text(achievedPct);
                            $('#spncompletes').text(complete);
                            $('#spnTotalcomplete').text(total);
                            $('#spnpercentIR').text(kpi.actIRPercent ?? kpi.ActIRPercent ?? kpi.actIrPercent ?? '0');
                            $('#spnLOI').text(kpi.actLOI ?? kpi.ActLOI ?? kpi.actLoi ?? '0');
                        } else {
                            $('#lblCompletion').text('0');
                            $('#spncompletes').text('0');
                            $('#spnTotalcomplete').text('0');
                            $('#spnpercentIR').text('0');
                            $('#spnLOI').text('0');
                        }
                    },
                    error: function () {
                        // ignore for now
                    }
                });
            }

            function GetRecontactProjectDetails() {
                var id = getquerystringid();
                $.ajax({
                    type: 'POST',
                    url: '/VT/RecontactPageDetails/FetchRecontactProjects',
                    contentType: 'application/json; charset=utf-8',
                    data: JSON.stringify({ Id: parseInt(id, 10), Opt: 0 }),
                    success: function (response) {
                        var data = response && response.d ? response.d : response || [];
                        var remainingdetails = data[3] || [];
                        if (remainingdetails.length > 0) {
                            var d = remainingdetails[0];
                            $('#lnlPnumber').text(d.projectNumber ?? d.ProjectNumber ?? '');
                            $('#lblPname').text(d.rProjectName ?? d.RProjectName ?? '');
                            $('#txtRecontactDescription').val(d.rProjectDescription ?? d.RProjectDescription ?? '');
                            $('#txtLOI').val(d.loi ?? d.LOI ?? '');
                            $('#txtIR').val(d.ir ?? d.IR ?? '');
                            $('#txtCPI').val(d.cpi ?? d.CPI ?? '');
                            $('#txtRCQ').val(d.rcq ?? d.RCQ ?? '');
                            $('#txtNOTES').val(d.notes ?? d.Notes ?? '');
                            $('#hfId').val(id);
                            $('#modal_EditRecontactProject').modal('show');
                        }
                    }
                });
            }
            window.GetRecontactProjectDetails = GetRecontactProjectDetails;

            function GetFormData() {
                var obj = {};
                obj.ID = parseInt($('#hfId').val() || getquerystringid(), 10);
                obj.RecontactDescription = $('#txtRecontactDescription').val() || '';
                obj.LOI = parseInt($('#txtLOI').val() || '0', 10);
                obj.IR = parseInt($('#txtIR').val() || '0', 10);
                obj.CPI = parseFloat($('#txtCPI').val() || '0');
                obj.RCQ = parseInt($('#txtRCQ').val() || '0', 10);
                obj.Notes = $('#txtNOTES').val() || '';
                return obj;
            }

            function SaveRecontactDetails() {
                var formdata = GetFormData();
                $.ajax({
                    type: 'POST',
                    url: '/VT/RecontactPageDetails/UpdateRecontactProjects',
                    contentType: 'application/json; charset=utf-8',
                    data: JSON.stringify(formdata),
                    success: function (data) {
                        var result = (data && data.d) ? data.d : data;
                        // SP updateRecontactProjects: @@output=0 means success, @@output=1 means error
                        if (result === '0' || result === 0) {
                            $('#modal_EditRecontactProject').modal('hide');
                            LoadTable(formdata.ID, 0);
                            Swal.fire('Saved', 'Recontact project details have been updated.', 'success');
                        } else if (result === '1' || result === 1) {
                            Swal.fire('Error', 'Please try again', 'error');
                        } else {
                            Swal.fire('Error', 'Please contact administrator', 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Error', 'Please contact administrator', 'error');
                    }
                });
            }
            window.SaveRecontactDetails = SaveRecontactDetails;

            $(document).ready(function () {
                var id = getquerystringid();
                if (id) {
                    LoadTable(id, 0);
                }
            });
        })();
    </script>
}

