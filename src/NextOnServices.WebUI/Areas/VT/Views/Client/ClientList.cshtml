@model NextOnServices.VT.Infrastructure.ViewModels.Client.ClientViewModel
@{
    ViewData["Title"] = "Client List";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" />
<style>
    .vt-client-list-page {
        --vt-client-theme: #1d7874;
        --vt-client-theme-dark: #165c59;
        --vt-client-border: rgba(29, 120, 116, 0.22);
    }

    .vt-client-list-page .ref-page-title {
        margin-bottom: 1rem;
    }

    .vt-client-list-page .ref-page-title h1 {
        margin-bottom: 0.2rem;
    }

    .vt-client-list-page .card--table-section {
        border: 1px solid var(--vt-client-border);
        box-shadow: 0 6px 16px rgba(29, 120, 116, 0.08);
    }

    .vt-client-list-page .table-section-header {
        border-left-color: var(--vt-client-theme);
    }

    .vt-client-list-page .vt-client-link {
        color: var(--vt-client-theme);
        font-weight: 600;
        text-decoration: none;
    }

    .vt-client-list-page .vt-client-link:hover {
        color: var(--vt-client-theme-dark);
        text-decoration: underline;
    }

    .vt-client-list-page .ref-table-btn.tablebutton {
        min-width: 100px;
        height: 30px;
        padding: 0.28rem 0.55rem;
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1.1;
    }

    .vt-client-list-page .ref-table-btn.tablebutton.btn-primary {
        background: linear-gradient(135deg, var(--vt-client-theme) 0%, var(--vt-client-theme-dark) 100%);
        border-color: var(--vt-client-theme-dark);
    }

    .vt-client-list-page .ref-table-btn.tablebutton.btn-primary:hover {
        background: linear-gradient(135deg, var(--vt-client-theme-dark) 0%, #124a47 100%);
        border-color: #124a47;
    }

    .vt-client-list-page .table td:has(.ref-table-btn.tablebutton) {
        white-space: nowrap;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button {
        border: 0 !important;
        border-radius: 9999px !important;
        padding: 0.42rem 0.75rem !important;
        margin: 0 !important;
        font-size: 0.75rem !important;
        font-weight: 600 !important;
        line-height: 1 !important;
        color: #fff !important;
        display: inline-flex !important;
        align-items: center;
        gap: 0.35rem;
        box-shadow: none !important;
        background-image: none !important;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button .dt-btn-icon {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 12px;
        height: 12px;
        line-height: 0 !important;
        flex: 0 0 auto;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button .dt-btn-icon svg {
        width: 12px !important;
        height: 12px !important;
        display: block !important;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button > span:last-child {
        display: inline-flex !important;
        align-items: center !important;
        line-height: 1 !important;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button.btn-excel {
        background: #16a34a !important;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button.btn-csv {
        background: #475569 !important;
    }

    .vt-client-list-page .vt-ref-table-wrap .ref-dt-top .dt-buttons .dt-button:hover {
        filter: brightness(0.95);
    }

    .vt-client-list-page #Projects th:nth-child(6),
    .vt-client-list-page #Projects td:nth-child(6) {
        min-width: 80px;
    }

    .vt-client-list-page #Projects th:nth-child(7),
    .vt-client-list-page #Projects td:nth-child(7) {
        min-width: 118px;
    }

    @@media (max-width: 767.98px) {
        .vt-client-list-page .ref-table-btn.tablebutton {
            min-width: 96px;
        }
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-client-list-page">
    <div class="ref-page-title">
        <h1>Client List</h1>
        <p class="ref-subtitle">View and manage client company records and active status</p>
    </div>

    <div class="row">
        <div class="col-md-12 grid-margin stretch-card">
            <div class="card card--table-section vt-ref-table-card">
                <div class="card-body">
                    <p class="table-section-header">Client List</p>
                    <div class="vt-ref-table-wrap">
                        <div class="table-responsive">
                            <table class="table table-striped vt-ref-table ref-project-table" id="Projects">
                                <thead>
                                    <tr>
                                        <th>Company Name</th>
                                        <th>Contact Person</th>
                                        <th>Contact Number</th>
                                        <th>Email</th>
                                        <th>Country</th>
                                        <th>Edit</th>
                                        <th>Active (Yes/No)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model?.Clients != null && Model.Clients.Any())
                                    {
                                        foreach (var item in Model.Clients)
                                        {
                                            <tr>
                                                <td>
                                                    <a class="vt-client-link" href="@Url.Action("ClientPreview", "Client", new { area = "VT", eClientId = item.encClientId })">@item.Company</a>
                                                </td>
                                                <td>@item.Cperson</td>
                                                <td>@item.Cnumber</td>
                                                <td>@item.Cemail</td>
                                                <td>@item.Country</td>
                                                <td>
                                                    <button type="button" class="btn btn-info btn-sm ref-table-btn tablebutton" onclick="window.location.href='/VT/Client/AddClient/@item.encClientId'">Edit</button>
                                                </td>
                                                <td>
                                                    @if (item.IsActive == 1)
                                                    {
                                                        <button type="button" class="btn btn-success btn-sm ref-table-btn tablebutton" onclick="ChangeStatus(@item.ClientId,0,this)">Yes</button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-danger btn-sm ref-table-btn tablebutton" onclick="ChangeStatus(@item.ClientId,1,this)">No</button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">No clients found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            $('#Projects').DataTable({
                order: [],
                scrollX: false,
                autoWidth: false,
                dom: '<"ref-dt-top"Bf>t<"ref-dt-bottom"ip>',
                paging: true,
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pagingType: 'simple_numbers',
                info: true,
                language: {
                    search: "",
                    searchPlaceholder: "Search...",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty: "Showing 0 to 0 of 0 entries",
                    infoFiltered: "(filtered from _MAX_ total entries)",
                    paginate: { first: "First", last: "Last", next: "Next", previous: "Previous" }
                },
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: '<span class="dt-btn-icon" aria-hidden="true"><svg viewBox="0 0 24 24" width="12" height="12"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zm0 1.5L18.5 8H14zM8.3 17l1.9-3-1.8-3h1.8l1 1.8 1-1.8H14l-1.8 3 1.9 3h-1.8l-1.1-1.9L10 17z"/></svg></span><span>Excel</span>',
                        className: 'btn-excel',
                        titleAttr: 'Export to Excel',
                        filename: 'Data_Export'
                    },
                    {
                        extend: 'csvHtml5',
                        text: '<span class="dt-btn-icon" aria-hidden="true"><svg viewBox="0 0 24 24" width="12" height="12"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zm0 1.5L18.5 8H14zM8 16.2c-.9 0-1.6-.7-1.6-1.6V13c0-.9.7-1.6 1.6-1.6h1.6v1.1H8.2c-.3 0-.5.2-.5.5v1.3c0 .3.2.5.5.5h1.4V16.2zm2.5 0v-4.8h2.7v1.1h-1.4v.8H13v1.1h-1.2v.8h1.5v1.1zm3.3 0v-1.1h1.1c.2 0 .3-.1.3-.3 0-.1 0-.2-.1-.2l-1-.8c-.4-.3-.6-.7-.6-1.2 0-.8.6-1.3 1.4-1.3H16v1.1h-.9c-.2 0-.3.1-.3.2s0 .2.1.2l1 .8c.4.3.7.7.7 1.2 0 .8-.6 1.4-1.5 1.4z"/></svg></span><span>CSV</span>',
                        className: 'btn-csv',
                        titleAttr: 'Export to CSV',
                        filename: 'Data_Export'
                    }
                ]
            });
        });

        function ChangeStatus(Id, Status, curObj) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You want to change the status!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, change it!',
                customClass: {
                    confirmButton: 'btn btn-primary me-3',
                    cancelButton: 'btn btn-label-secondary'
                },
                buttonsStyling: false
            }).then(function (result) {
                if (result.isConfirmed) {
                    BlockUI();
                    var inputDTO = {};
                    inputDTO.ClientId = Id;
                    inputDTO.IsActive = Status;

                    $.ajax({
                        type: "POST",
                        url: "/VT/Client/ChangeClientStatus",
                        contentType: 'application/json',
                        data: JSON.stringify(inputDTO),
                        success: function () {
                            UnblockUI();
                            $successalert("Success", "Status changed");
                            var element = $(curObj).closest("td");
                            element.empty();
                            if (Status == 1) {
                                element.append('<button type="button" class="btn btn-success btn-sm ref-table-btn tablebutton" onclick="ChangeStatus(' + Id + ',0,this)">Yes</button>');
                            }
                            else {
                                element.append('<button type="button" class="btn btn-danger btn-sm ref-table-btn tablebutton" onclick="ChangeStatus(' + Id + ',1,this)">No</button>');
                            }
                        },
                        error: function (error) {
                            UnblockUI();
                            $erroralert("Error!", error.responseText);
                        }
                    });
                }
            });
        }
    </script>
}
