@model NextOnServices.VT.Infrastructure.ViewModels.Project.LucidMarketplaceViewModel
@{
    ViewData["Title"] = "Lucid Marketplace Logs";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />

<style>
    .vt-lm-logs-page {
        --vt-lm-theme: #125b50;
        --vt-lm-border: rgba(18, 91, 80, 0.2);
    }

    .vt-lm-logs-page .ref-page-title {
        margin-bottom: 1rem;
    }

    .vt-lm-logs-page .card--table-section {
        border: 1px solid var(--vt-lm-border);
        box-shadow: 0 8px 22px rgba(18, 91, 80, 0.08);
    }

    .vt-lm-logs-page .table-section-header {
        border-left-color: var(--vt-lm-theme);
    }

    .vt-lm-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 700;
    }

    .vt-lm-badge.success {
        background: rgba(22, 163, 74, 0.12);
        color: #166534;
    }

    .vt-lm-badge.error {
        background: rgba(239, 68, 68, 0.12);
        color: #991b1b;
    }

    .vt-lm-logs-page .text-truncate-cell {
        max-width: 220px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vt-lm-log-pre {
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 280px;
        overflow-y: auto;
        background: #f8fafc;
        border: 1px solid #dbe3ea;
        border-radius: 8px;
        padding: 0.75rem;
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-lm-logs-page">
    <div class="ref-page-title">
        <h1>Lucid Marketplace Logs</h1>
        <p class="ref-subtitle">Track subscription API calls, callback receives, parse attempts, and opportunity save activity for the new Lucid Marketplace module.</p>
    </div>

    <div class="row">
        <div class="col-md-12 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <h4 class="table-section-header">API / Sync Logs</h4>
                    <div class="table-responsive mt-3">
                        <table class="table table-striped vt-ref-table ref-project-table" id="LucidMarketplaceLogsTable">
                            <thead>
                                <tr>
                                    <th>Action</th>
                                    <th>Supplier</th>
                                    <th>Survey ID</th>
                                    <th>Request URL</th>
                                    <th>Source</th>
                                    <th>Status Code</th>
                                    <th>Success</th>
                                    <th>Started On</th>
                                    <th>Completed On</th>
                                    <th>Error</th>
                                    <th>View Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Logs.Any())
                                {
                                    foreach (var item in Model.Logs)
                                    {
                                        <tr>
                                            <td>@item.ActionName</td>
                                            <td>@item.SupplierCode</td>
                                            <td>@(item.RelatedSurveyId?.ToString() ?? "-")</td>
                                            <td class="text-truncate-cell" title="@item.RequestUrl">@item.RequestUrl</td>
                                            <td>@item.Source</td>
                                            <td>@(item.ResponseStatusCode?.ToString() ?? "-")</td>
                                            <td><span class="vt-lm-badge @(item.IsSuccess ? "success" : "error")">@(item.IsSuccess ? "Success" : "Failed")</span></td>
                                            <td>@item.StartedOn?.ToString("dd MMM yyyy hh:mm tt")</td>
                                            <td>@item.CompletedOn?.ToString("dd MMM yyyy hh:mm tt")</td>
                                            <td class="text-truncate-cell" title="@item.ErrorText">@item.ErrorText</td>
                                            <td><button type="button" class="btn btn-outline-primary btn-sm" onclick="viewLucidMarketplaceLog(@item.LucidMarketplaceSyncLogId)">Details</button></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="11" class="text-center text-muted py-4">No Lucid Marketplace logs are available yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="lucidMarketplaceLogModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Lucid Marketplace Log Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="font-weight-600 mb-1">Request Body</div>
                    <div id="lmLogRequest" class="vt-lm-log-pre"></div>
                </div>
                <div class="mb-3">
                    <div class="font-weight-600 mb-1">Response Body</div>
                    <div id="lmLogResponse" class="vt-lm-log-pre"></div>
                </div>
                <div>
                    <div class="font-weight-600 mb-1">Error</div>
                    <div id="lmLogError" class="vt-lm-log-pre"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#LucidMarketplaceLogsTable').DataTable({
                order: [[7, 'desc']],
                paging: true,
                pageLength: 25,
                scrollX: true,
                autoWidth: false,
                language: {
                    search: "",
                    searchPlaceholder: "Search logs..."
                }
            });
        });

        function viewLucidMarketplaceLog(logId) {
            $.ajax({
                type: "GET",
                url: "/VT/LucidMarketplaceApi/LogDetails/" + logId,
                success: function (response) {
                    $("#lmLogRequest").text(response.requestBodySnapshot || "No request payload captured.");
                    $("#lmLogResponse").text(response.responseBodySnapshot || "No response payload captured.");
                    $("#lmLogError").text(response.errorText || "No error recorded.");
                    $("#lucidMarketplaceLogModal").modal("show");
                },
                error: function (xhr) {
                    Swal.fire("Error", xhr.responseText || "Unable to load log details.", "error");
                }
            });
        }
    </script>
}
