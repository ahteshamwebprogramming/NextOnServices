@model NextOnServices.Infrastructure.ViewModels.Settings.HashingSettingsViewModel
@{
    ViewData["Title"] = "Hashing Settings";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
    var isEditMode = Model?.Form?.HashingSettingId > 0;
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />

<style>
    .vt-hashing-settings-page {
        --vt-hash-theme: #1d7874;
        --vt-hash-theme-dark: #145b58;
        --vt-hash-border: rgba(29, 120, 116, 0.22);
        --vt-hash-soft: rgba(29, 120, 116, 0.08);
    }

    .vt-hashing-settings-page .ref-page-title {
        margin-bottom: 1rem;
    }

    .vt-hashing-settings-page .card--table-section {
        border: 1px solid var(--vt-hash-border);
        box-shadow: 0 6px 18px rgba(29, 120, 116, 0.08);
    }

    .vt-hashing-settings-page .table-section-header {
        border-left-color: var(--vt-hash-theme);
    }

    .vt-hashing-settings-page .form-control,
    .vt-hashing-settings-page .form-control-sm {
        border-radius: 8px;
    }

    .vt-hashing-settings-page .required::after {
        content: " *";
        color: #dc2626;
    }

    .vt-hashing-settings-page .vt-secret-preview {
        font-family: Consolas, "Courier New", monospace;
        font-size: 0.8rem;
        color: #334155;
    }

    .vt-hashing-settings-page .alert {
        border-radius: 10px;
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-hashing-settings-page">
    <div class="ref-page-title">
        <h1>Hashing Settings</h1>
        <p class="ref-subtitle">Manage the hashing key used for each supported hashing type. These records drive project mapping hashing and legacy status-share flows.</p>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">@successMessage</div>
    }

    <div class="row">
        <div class="col-lg-5 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <h4 class="table-section-header">@(isEditMode ? "Edit Hashing Record" : "Add Hashing Record")</h4>
                    <p class="card-description mb-3">Store one active key per hashing type.</p>

                    <form asp-action="HashingSettings" asp-controller="Settings" asp-area="VT" method="post" class="forms-sample">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                        <input asp-for="Form.HashingSettingId" type="hidden" />

                        <div class="form-group">
                            <label asp-for="Form.HashingType" class="required">Hashing Type</label>
                            <select asp-for="Form.HashingType" class="form-control form-control-sm">
                                <option value="">-- Select Hashing Type --</option>
                                @foreach (var hashingType in Model.SupportedHashingTypes)
                                {
                                    <option value="@hashingType">@hashingType</option>
                                }
                            </select>
                            <span asp-validation-for="Form.HashingType" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Form.HashingKey" class="required">Hashing Key</label>
                            <input asp-for="Form.HashingKey" class="form-control form-control-sm" autocomplete="off" />
                            <span asp-validation-for="Form.HashingKey" class="text-danger"></span>
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary btn-sm mr-2">@(isEditMode ? "Update Record" : "Save Record")</button>
                            @if (isEditMode)
                            {
                                <a class="btn btn-light btn-sm" href="/VT/Settings/HashingSettings">Cancel</a>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <h4 class="table-section-header">Configured Records</h4>
                    <p class="card-description mb-3">Latest active entries are used automatically when hashing is enabled on a project mapping.</p>

                    <div class="table-responsive">
                        <table class="table table-striped vt-ref-table">
                            <thead>
                                <tr>
                                    <th>Hashing Type</th>
                                    <th>Hashing Key</th>
                                    <th>Updated On</th>
                                    <th>Edit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Items != null && Model.Items.Any())
                                {
                                    @foreach (var item in Model.Items)
                                    {
                                        var key = item.HashingKey ?? string.Empty;
                                        var keyPreview = string.IsNullOrWhiteSpace(key)
                                            ? "-"
                                            : key.Length <= 6
                                                ? key
                                                : $"{new string('*', Math.Max(0, key.Length - 4))}{key[^4..]}";
                                        var updatedOn = item.ModifiedDate ?? item.CreatedDate;
                                        <tr>
                                            <td>@item.HashingType</td>
                                            <td class="vt-secret-preview">@keyPreview</td>
                                            <td>@(updatedOn?.ToString("dd MMM yyyy hh:mm tt") ?? "-")</td>
                                            <td>
                                                <a class="btn btn-info btn-sm" href="/VT/Settings/HashingSettings?id=@item.HashingSettingId">Edit</a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">No hashing settings found yet. Add the first record from the form.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <partial name="_ValidationScriptsPartial" />
}
