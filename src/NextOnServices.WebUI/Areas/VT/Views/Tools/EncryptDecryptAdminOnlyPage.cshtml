@{
    ViewData["Title"] = "Encrypt / Decrypt (Admin Only)";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
@model NextOnServices.Infrastructure.Models.Account.AdminEncryption

<div class="container-fluid mt-3">
    <h4>Encrypt / Decrypt (Admin Only)</h4>
    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Encrypt Password
                </div>
                <div class="card-body">
                    <form method="post" action="/VT/EncryptPassword">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="EncryptInput" class="form-label">Plain Text</label>
                            <textarea asp-for="EncryptInput" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="EncryptInput" class="text-danger"></span>
                        </div>
                        <div class="form-text mb-3">Uses the same encryption mechanism as `VT/Supplier/Login`.</div>
                        <button type="submit" class="btn btn-primary">Encrypt</button>
                        @if (!string.IsNullOrWhiteSpace(Model?.EncryptOutput))
                        {
                            <div id="encryptResultPanel" class="alert alert-success mt-3 mb-0">
                                <div class="font-weight-bold mb-2">Encrypted Value</div>
                                <pre class="mb-0" style="white-space: pre-wrap; word-break: break-all;">@Model.EncryptOutput</pre>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Decrypt Password
                </div>
                <div class="card-body">
                    <form method="post" action="/VT/DecryptPassword">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="DecryptInput" class="form-label">Encrypted Text</label>
                            <textarea asp-for="DecryptInput" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="DecryptInput" class="text-danger"></span>
                        </div>
                        <div class="form-text mb-3">Decrypts values produced by the supplier login password mechanism.</div>
                        <button type="submit" class="btn btn-success">Decrypt</button>
                        @if (!string.IsNullOrWhiteSpace(Model?.DecryptOutput))
                        {
                            <div id="decryptResultPanel" class="alert alert-success mt-3 mb-0">
                                <div class="font-weight-bold mb-2">Decrypted Value</div>
                                <pre class="mb-0" style="white-space: pre-wrap; word-break: break-all;">@Model.DecryptOutput</pre>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var resultPanel = document.getElementById('encryptResultPanel') || document.getElementById('decryptResultPanel');
            if (resultPanel) {
                resultPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
}

