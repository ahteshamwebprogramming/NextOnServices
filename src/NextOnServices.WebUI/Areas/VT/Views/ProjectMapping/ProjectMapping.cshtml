@model NextOnServices.Infrastructure.ViewModels.ProjectMapping.ProjectMappingViewModel
@{
    ViewData["Title"] = "Project Mapping";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/tooltip.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />
<style>
    .vt-project-mapping-page {
        --vt-map-theme: #1d7874;
        --vt-map-theme-dark: #165c59;
        --vt-map-border: rgba(29, 120, 116, 0.22);
        --vt-map-soft: rgba(29, 120, 116, 0.08);
    }

    .vt-project-mapping-page .ref-page-title {
        margin-bottom: 1rem;
    }

    .vt-project-mapping-page .ref-page-title h1 {
        margin-bottom: 0.2rem;
    }

    .vt-project-mapping-page .vt-map-block {
        margin-bottom: 0.25rem;
    }

    .vt-project-mapping-page .table-section-header {
        border-left-color: var(--vt-map-theme);
    }

    .vt-project-mapping-page .card--table-section {
        border: 1px solid var(--vt-map-border);
        box-shadow: 0 6px 16px rgba(29, 120, 116, 0.08);
    }

    .vt-project-mapping-page .vt-mapping-toggle-wrap {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding: 0.65rem 0.85rem;
        background: linear-gradient(135deg, #fff 0%, var(--vt-map-soft) 100%);
        border: 1px solid var(--vt-map-border);
        border-radius: 10px;
    }

    .vt-project-mapping-page .vt-mapping-toggle-wrap .form-check {
        margin: 0;
        padding-left: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
    }

    .vt-project-mapping-page .vt-mapping-toggle-wrap .form-check-input {
        position: static;
        margin: 0;
        width: 1rem;
        height: 1rem;
        flex: 0 0 auto;
    }

    .vt-project-mapping-page .vt-mapping-toggle-wrap .form-check-label {
        margin: 0;
        font-weight: 600;
        line-height: 1.2;
        color: #0f172a;
    }

    .vt-project-mapping-page .vt-map-help {
        margin: 0;
        margin-left: auto;
        display: flex;
        align-items: center;
        text-align: right;
        line-height: 1.35;
        font-size: 0.75rem;
        color: #64748b;
    }

    .vt-project-mapping-page .vt-project-name-readonly {
        background-color: #f8fafc !important;
        border: 1px solid #dbe3ea !important;
        border-radius: 8px !important;
        color: #334155 !important;
        font-weight: 500;
    }

    .vt-project-mapping-page .vt-map-link-cell {
        max-width: 260px;
        white-space: normal;
        word-break: break-word;
    }

    .vt-project-mapping-page .vt-map-check {
        text-align: center;
    }

    .vt-project-mapping-page .vt-map-check input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        cursor: pointer;
        accent-color: var(--vt-map-theme);
    }

    .vt-project-mapping-page .ref-table-btn {
        min-width: 84px;
    }

    .vt-project-mapping-page #ProjectMappingForm .form-control.form-control-sm {
        height: 38px !important;
        min-height: 38px !important;
        padding-top: 0.35rem !important;
        padding-bottom: 0.35rem !important;
    }

    .vt-project-mapping-page #ProjectMappingForm .select2-container {
        width: 100% !important;
    }

    .vt-project-mapping-page #ProjectMappingForm .select2-container--default .select2-selection--single {
        height: 38px !important;
        min-height: 38px !important;
        border: 1px solid #dbe3ea !important;
        border-radius: 8px !important;
        padding: 0 2.15rem 0 0.75rem !important;
        display: flex !important;
        align-items: center !important;
    }

    .vt-project-mapping-page #ProjectMappingForm .select2-container--default .select2-selection--single .select2-selection__rendered {
        height: 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        line-height: 1.2 !important;
        display: inline-flex !important;
        align-items: center !important;
        color: #1f2937 !important;
    }

    .vt-project-mapping-page #ProjectMappingForm .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 100% !important;
        width: 1.75rem !important;
        right: 0.45rem !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
    }

    .vt-project-mapping-page #ProjectMappingForm .select2-container--default .select2-selection--single .select2-selection__arrow b {
        margin-top: 0 !important;
    }

    .vt-project-mapping-page #ProjectMappingForm textarea.form-control.form-control-sm {
        height: auto !important;
        min-height: 72px !important;
        padding-top: 0.5rem !important;
        padding-bottom: 0.5rem !important;
    }

    @@media (max-width: 767.98px) {
        .vt-project-mapping-page .vt-mapping-toggle-wrap {
            align-items: flex-start;
        }

        .vt-project-mapping-page .vt-map-help {
            margin-left: 0;
            text-align: left;
        }
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-project-mapping-page">
    <div class="ref-page-title">
        <h1>Project Mapping</h1>
        <p class="ref-subtitle">Configure country-supplier sampling links for this project</p>
    </div>

    <div class="row vt-map-block">
        <div id="PartialView_AddProjectMapping" class="w-100">
            @Html.Partial("_projectMapping/_addProjectMapping")
        </div>
    </div>
    <div class="row vt-map-block">
        <div id="PartialView_ListProjectMapping" class="w-100">
            @Html.Partial("_projectMapping/_listProjectMapping")
        </div>
    </div>

    <input type="hidden" asp-for="ProjectMappingWithChild.encProjectId" />
</div>

@section scripts {
    <script src="~/customJS/ProjectMapping/ProjectMapping.js" asp-append-version="true"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            AddProjectMappingPartialView();
            ListProjectMappingPartialView();
        });
    </script>
}
