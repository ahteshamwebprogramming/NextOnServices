@model NextOnServices.Infrastructure.ViewModels.ProjectQuestionsMapping.ProjectQuestionsMappingViewModel
@using NextOnServices.Infrastructure.Helper;
@{
    ViewData["Title"] = "Mapping";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
    string projectIdEnc = ViewBag.ProjectIdEnc?.ToString() ?? (Model?.Project != null ? CommonHelper.EncryptURLHTML(Model.Project.ProjectId.ToString()) : "");
}

<style>
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 24px;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 24px;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 18px;
        width: 18px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    input:checked + .slider {
        background-color: #2196F3;
    }

    input:checked + .slider:before {
        transform: translateX(26px);
    }

    .questions-table-container {
        max-height: 500px;
        overflow-y: auto;
    }

    .breadcrumb-wrapper {
        margin-bottom: 20px;
    }

    .btn-teal-primary {
        background-color: #00796b;
        color: #ffffff;
        border: none;
        border-radius: 4px;
        padding: 10px 20px;
        font-weight: 500;
        text-transform: uppercase;
        transition: background-color 0.3s;
    }

    .btn-teal-primary:hover {
        background-color: #005f56;
        color: #ffffff;
    }

    .btn-teal-primary:focus {
        background-color: #005f56;
        color: #ffffff;
        box-shadow: 0 0 0 0.2rem rgba(0, 121, 107, 0.5);
    }
</style>

<div class="breadcrumb-wrapper">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/VT/Home/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="#">Pre Screening</a></li>
            <li class="breadcrumb-item active" aria-current="page">Mapping</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4">Mapping</h4>
                
                <div class="row mb-4">
                    <div class="col-md-12">
                        <h5>Project/Questions Mapping</h5>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="ddlProject" class="font-weight-medium">PROJECT</label>
                            <select class="form-control form-control-sm" id="ddlProject">
                                <option value="">--Select Project--</option>
                                @if (Model?.Project != null)
                                {
                                    <option value="@projectIdEnc" selected>@Model.Project.Pname</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="ddlCountry" class="font-weight-medium">COUNTRY</label>
                            <select class="form-control form-control-sm" id="ddlCountry">
                                <option value="0">--Select Country--</option>
                                @if (Model?.Countries != null)
                                {
                                    foreach (var country in Model.Countries)
                                    {
                                        <option value="@country.CountryId">@country.Country</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="table-responsive questions-table-container">
                            <table class="table table-striped table-borderless" id="questionsTable">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">
                                            <input type="checkbox" id="chkSelectAll" />
                                        </th>
                                        <th>QUESTION ID</th>
                                        <th>LABEL</th>
                                    </tr>
                                </thead>
                                <tbody id="questionsTableBody">
                                    @if (Model?.Questions != null)
                                    {
                                        foreach (var question in Model.Questions)
                                        {
                                            <tr>
                                                <td>
                                                    <input type="checkbox" class="question-checkbox" data-question-id="@question.Id" data-question-id-text="@question.QuestionId" />
                                                </td>
                                                <td>@question.QuestionId</td>
                                                <td>@question.QuestionLabel</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title mb-3">Display Settings</h6>
                                
                                <div class="form-group mb-3">
                                    <label class="d-flex justify-content-between align-items-center">
                                        <span>Show previous button</span>
                                        <label class="toggle-switch mb-0">
                                            <input type="checkbox" id="chkPreviousButton">
                                            <span class="slider"></span>
                                        </label>
                                    </label>
                                </div>

                                <div class="form-group mb-3">
                                    <label class="d-flex justify-content-between align-items-center">
                                        <span>Show question ID</span>
                                        <label class="toggle-switch mb-0">
                                            <input type="checkbox" id="chkQuestionID">
                                            <span class="slider"></span>
                                        </label>
                                    </label>
                                </div>

                                <div class="form-group mb-3">
                                    <label class="d-flex justify-content-between align-items-center">
                                        <span>Show Logo</span>
                                        <label class="toggle-switch mb-0">
                                            <input type="checkbox" id="chkLogo">
                                            <span class="slider"></span>
                                        </label>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12">
                        <div class="d-flex justify-content-center" style="gap: 15px;">
                            <button type="button" class="btn btn-teal-primary" onclick="SaveAndNext()">SAVE AND NEXT</button>
                            <button type="button" class="btn btn-teal-primary" onclick="BackToProjectDashboard()">BACK TO PROJECT DASHBOARD</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="hdnProjectIdEnc" value="@projectIdEnc" />
<input type="hidden" id="hdnMappingId" value="0" />

@section Scripts {
    <script src="~/customJS/ProjectQuestionsMapping/ProjectQuestionsMapping.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            InitializeProjectQuestionsMapping();
        });
    </script>
}

