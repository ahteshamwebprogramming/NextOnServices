@using System.Linq
@model NextOnServices.VT.Infrastructure.ViewModels.Project.TorfacMarketplaceViewModel
@{
    ViewData["Title"] = "Torfac Marketplace Settings";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/validation.css" rel="stylesheet" asp-append-version="true" />

<style>
    .vt-torfac-settings-page {
        --vt-torfac-theme: #8a4b14;
        --vt-torfac-border: rgba(138, 75, 20, 0.18);
    }

    .vt-torfac-settings-page .card--table-section {
        border: 1px solid rgba(138, 75, 20, 0.18);
        box-shadow: 0 10px 24px rgba(138, 75, 20, 0.08);
    }

    .vt-torfac-settings-page .table-section-header {
        border-left-color: #8a4b14;
    }

    .vt-torfac-settings-page .vt-form-section {
        margin-bottom: 0.9rem;
        padding: 0.55rem 0.8rem;
        border-radius: 10px;
        border: 1px solid var(--vt-torfac-border);
        background: linear-gradient(135deg, #fff 0%, rgba(138, 75, 20, 0.07) 100%);
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #5b3110;
    }

    .vt-torfac-settings-page .form-control {
        border-radius: 10px;
        border-color: #e5d6c8;
    }

    .vt-torfac-settings-page .select2-container {
        width: 100% !important;
    }

    .vt-torfac-settings-page .required::after {
        content: " *";
        color: #dc2626;
    }

    .vt-torfac-settings-page .switch-wrap {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-height: 38px;
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-torfac-settings-page">
    <div class="ref-page-title">
        <h1>Torfac Marketplace Settings</h1>
        <p class="ref-subtitle">Store the Torfac survey feed URL and secret key here so the Get Surveys page can pull the remote survey payload from the saved configuration.</p>
    </div>

    <div class="row">
        <div class="col-md-12 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <h4 class="table-section-header">Configuration</h4>
                    <form id="TorfacMarketplaceSettingsForm" class="forms-sample">
                        <div class="vt-form-section">Survey Source</div>
                        <div class="row">
                            <div class="form-group col-md-8">
                                <label class="required">Survey URL</label>
                                <input asp-for="Setting.SurveysUrl" class="form-control form-control-sm requiredInput" placeholder="https://vendor.example.com/api/surveys" />
                                <small class="text-muted d-block mt-2">This is the exact Torfac URL the Get Surveys page will call.</small>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Secret Key</label>
                                <input asp-for="Setting.SecretKey" type="password" class="form-control form-control-sm" autocomplete="new-password" />
                                <small class="text-muted d-block mt-2">Required the first time you save settings. Leave the value in place unless you want to replace it.</small>
                            </div>
                        </div>

                        <div class="vt-form-section">Module State</div>
                        <div class="row">
                            <div class="form-group col-md-4">
                                <label>Is Active</label>
                                <div class="switch-wrap">
                                    <input asp-for="Setting.IsActive" type="checkbox" />
                                    <span>Enable Torfac Marketplace in VT</span>
                                </div>
                            </div>
                        </div>

                        <div class="vt-form-section">Default Mapping</div>
                        <div class="row">
                            <div class="form-group col-md-8">
                                <label>Default Suppliers</label>
                                <select asp-for="Setting.DefaultSupplierIds" class="form-control form-control-sm select2" multiple>
                                    @foreach (var supplier in Model.Suppliers.Where(x => x.IsActive == 1 || x.IsActive == null))
                                    {
                                        <option value="@supplier.Id">@supplier.Name</option>
                                    }
                                </select>
                                <small class="text-muted d-block mt-2">When a Torfac project is added, one supplier mapping is created for each selected supplier. Mapping CPI uses 40% of the project CPI and mapping quota matches the project quota.</small>
                            </div>
                        </div>

                        <input asp-for="Setting.TorfacMarketplaceSettingId" type="hidden" />

                        <div class="mt-3">
                            <button type="button" class="btn btn-primary btn-sm mr-2" onclick="saveTorfacMarketplaceSettings()">Save Settings</button>
                            <a class="btn btn-info btn-sm mr-2" href="/VT/TorfacMarketplace/GetSurveys">Open Get Surveys</a>
                            <a class="btn btn-light btn-sm" href="/VT/TorfacMarketplace">Back to Dashboard</a>
                        </div>
                    </form>
                    <div class="mt-4">
                        <small class="text-muted">Current fetch behavior assumes the secret key is sent as request headers. If Torfac expects a different auth pattern, we can adapt it quickly once we verify the vendor contract.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/customJS/Validation.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $(".select2").select2({ dropdownCssClass: "vt-theme-dropdown", width: "100%" });
        });

        function buildTorfacMarketplaceSettingsPayload() {
            const $form = $("#TorfacMarketplaceSettingsForm");
            return {
                torfacMarketplaceSettingId: parseInt($form.find("[name='Setting.TorfacMarketplaceSettingId']").val() || "0", 10),
                surveysUrl: $form.find("[name='Setting.SurveysUrl']").val(),
                secretKey: $form.find("[name='Setting.SecretKey']").val(),
                defaultSupplierIds: parseIntArray($form.find("[name='Setting.DefaultSupplierIds']").val()),
                isActive: $form.find("[name='Setting.IsActive']").is(":checked")
            };
        }

        function parseIntArray(values) {
            if (!values || !values.length) {
                return [];
            }

            return values
                .map(function (value) { return parseInt(value, 10); })
                .filter(function (value) { return !isNaN(value) && value > 0; });
        }

        function saveTorfacMarketplaceSettings() {
            if (!isValidateForm("TorfacMarketplaceSettingsForm")) {
                return;
            }

            const payload = buildTorfacMarketplaceSettingsPayload();
            if (payload.torfacMarketplaceSettingId <= 0 && !(payload.secretKey || "").trim()) {
                Swal.fire("Required", "Enter a secret key before saving new Torfac Marketplace settings.", "warning");
                return;
            }

            $.ajax({
                type: "POST",
                url: "/VT/TorfacMarketplaceApi/SaveSettings",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function () {
                    Swal.fire("Success", "Torfac Marketplace settings saved successfully.", "success")
                        .then(function () { window.location.reload(); });
                },
                error: function (xhr) {
                    Swal.fire("Error", xhr.responseJSON?.message || xhr.responseText || "Unable to save Torfac Marketplace settings.", "error");
                }
            });
        }
    </script>
}
