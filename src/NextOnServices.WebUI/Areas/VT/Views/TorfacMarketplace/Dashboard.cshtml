@model NextOnServices.VT.Infrastructure.ViewModels.Project.TorfacMarketplaceViewModel
@{
    ViewData["Title"] = "Torfac Marketplace Dashboard";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
    var configuredUrl = string.IsNullOrWhiteSpace(Model?.Setting?.SurveysUrl) ? "Not configured yet" : Model.Setting.SurveysUrl;
    var moduleStatus = Model?.Setting?.IsActive == true ? "Active" : "Inactive";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />

<style>
    .vt-torfac-page {
        --vt-torfac-theme: #8a4b14;
        --vt-torfac-soft: rgba(138, 75, 20, 0.08);
        --vt-torfac-border: rgba(138, 75, 20, 0.18);
    }

    .vt-torfac-page .card--table-section {
        border: 1px solid var(--vt-torfac-border);
        box-shadow: 0 10px 24px rgba(138, 75, 20, 0.08);
    }

    .vt-torfac-page .table-section-header {
        border-left-color: var(--vt-torfac-theme);
    }

    .vt-torfac-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .vt-torfac-stat {
        padding: 1rem;
        border-radius: 14px;
        border: 1px solid var(--vt-torfac-border);
        background: linear-gradient(145deg, #ffffff 0%, #fff7ef 100%);
    }

    .vt-torfac-stat__label {
        display: block;
        font-size: 0.82rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.45rem;
    }

    .vt-torfac-stat__value {
        display: block;
        font-size: 1.55rem;
        font-weight: 700;
        color: #5b3110;
        line-height: 1.2;
    }

    .vt-torfac-links .btn {
        min-width: 170px;
        margin-right: 0.5rem;
        margin-bottom: 0.5rem;
    }
</style>

<div class="vt-project-page vt-dashboard-ref ref-content-wrap vt-torfac-page">
    <div class="ref-page-title">
        <h1>Torfac Marketplace Dashboard</h1>
        <p class="ref-subtitle">The VT navigation shell for Torfac Marketplace is now in place so survey and settings work can grow into a dedicated module.</p>
    </div>

    <div class="row">
        <div class="col-md-12 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <h4 class="table-section-header mb-3 mb-md-0">Module Overview</h4>
                        <div class="vt-torfac-links">
                            <a class="btn btn-outline-primary btn-sm" href="/VT/TorfacMarketplace/GetSurveys">Get Surveys</a>
                            <a class="btn btn-outline-secondary btn-sm" href="/VT/TorfacMarketplace/Settings">Settings</a>
                        </div>
                    </div>

                        <div class="vt-torfac-grid">
                        <div class="vt-torfac-stat">
                            <span class="vt-torfac-stat__label">Module Status</span>
                            <span class="vt-torfac-stat__value">@moduleStatus</span>
                        </div>
                        <div class="vt-torfac-stat">
                            <span class="vt-torfac-stat__label">Survey URL</span>
                            <span class="vt-torfac-stat__value">@configuredUrl</span>
                        </div>
                        <div class="vt-torfac-stat">
                            <span class="vt-torfac-stat__label">Fetch Flow</span>
                            <span class="vt-torfac-stat__value">Settings to Get Surveys</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
