@model NextOnServices.Infrastructure.Models.Account.UserDTO
@using NextOnServices.Infrastructure.Helper
@{
    ViewData["Title"] = "User Profile";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";

    var userCode = string.IsNullOrWhiteSpace(Model?.UserCode) ? "-" : Model!.UserCode!;
    var displayName = !string.IsNullOrWhiteSpace(Model?.UserName)
        ? Model!.UserName!
        : (!string.IsNullOrWhiteSpace(Model?.UserCode) ? Model!.UserCode! : "User");
    var emailId = string.IsNullOrWhiteSpace(Model?.EmailId) ? "-" : Model!.EmailId!;
    var contactNumber = string.IsNullOrWhiteSpace(Model?.ContactNumber) ? "-" : Model!.ContactNumber!;
    var address = string.IsNullOrWhiteSpace(Model?.Address) ? "No address available" : Model!.Address!;
    var country = string.IsNullOrWhiteSpace(Model?.Country) ? "-" : Model!.Country!;
    var rating = string.IsNullOrWhiteSpace(Model?.Rating) ? "-" : Model!.Rating!;
    var projects = string.IsNullOrWhiteSpace(Model?.Projects) ? "-" : Model!.Projects!;
    var roleLabel = Model?.UserType == "A" ? "Admin" : Model?.UserType == "U" ? "User" : (Model?.UserType ?? "-");
    var isActive = (Model?.IsActive ?? 0) == 1;
    var statusLabel = isActive ? "Active" : "Inactive";
    var createdDate = Model?.CreatedDate?.ToString("dd MMM yyyy") ?? "-";
    var initials = string.Join(
        "",
        displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(x => char.ToUpperInvariant(x[0]))
    );
    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }
}
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<style>
    .vt-user-profile-page {
        --profile-primary: #0f7f79;
        --profile-primary-deep: #165c59;
        --profile-border: #dce7ed;
        --profile-text: #0f172a;
        --profile-muted: #526477;
    }

    .vt-user-profile-page .vt-profile-shell {
        border: 1px solid rgba(15, 127, 121, 0.22);
        border-radius: 14px;
        box-shadow: 0 8px 22px rgba(10, 48, 58, 0.08);
        overflow: hidden;
        background: #fff;
    }

    .vt-user-profile-page .vt-profile-shell .card-body {
        padding: 0;
    }

    .vt-user-profile-page .vt-profile-hero {
        background: linear-gradient(140deg, #f1fbfa 0%, #e6f2ff 100%);
        padding: 1.2rem 1.3rem;
        border-bottom: 1px solid var(--profile-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .vt-user-profile-page .vt-profile-main {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        min-width: 0;
    }

    .vt-user-profile-page .vt-profile-avatar {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: linear-gradient(145deg, var(--profile-primary) 0%, var(--profile-primary-deep) 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        box-shadow: 0 6px 16px rgba(15, 127, 121, 0.26);
        flex-shrink: 0;
    }

    .vt-user-profile-page .vt-profile-title {
        margin: 0;
        font-size: 1.22rem;
        line-height: 1.2;
        font-weight: 700;
        color: var(--profile-text);
        word-break: break-word;
    }

    .vt-user-profile-page .vt-profile-sub {
        margin: 0.12rem 0 0;
        font-size: 0.84rem;
        color: var(--profile-muted);
        font-weight: 600;
    }

    .vt-user-profile-page .vt-profile-tags {
        margin-top: 0.45rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .vt-user-profile-page .vt-tag {
        border-radius: 999px;
        padding: 0.18rem 0.58rem;
        font-size: 0.72rem;
        font-weight: 700;
        line-height: 1.2;
        border: 1px solid transparent;
    }

    .vt-user-profile-page .vt-tag-role {
        color: #075985;
        background: #e0f2fe;
        border-color: #bae6fd;
    }

    .vt-user-profile-page .vt-tag-status-active {
        color: #166534;
        background: #dcfce7;
        border-color: #bbf7d0;
    }

    .vt-user-profile-page .vt-tag-status-inactive {
        color: #7c2d12;
        background: #ffedd5;
        border-color: #fed7aa;
    }

    .vt-user-profile-page .vt-profile-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .vt-user-profile-page .vt-profile-actions .btn {
        height: 38px;
        min-height: 38px;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-align: center !important;
        vertical-align: middle;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 700;
        line-height: 1.1 !important;
        padding: 0 0.95rem !important;
    }

    .vt-user-profile-page .vt-profile-actions .btn-primary {
        background: linear-gradient(135deg, var(--profile-primary) 0%, var(--profile-primary-deep) 100%);
        border-color: var(--profile-primary-deep);
    }

    .vt-user-profile-page .vt-profile-actions .btn-light {
        border: 1px solid #d4e0e8;
        background: #fff;
        color: #334155;
    }

    .vt-user-profile-page .vt-profile-body {
        padding: 1.1rem 1.2rem 1.2rem;
    }

    .vt-user-profile-page .vt-info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
        margin-bottom: 0.8rem;
    }

    .vt-user-profile-page .vt-info-card {
        border: 1px solid var(--profile-border);
        border-radius: 12px;
        background: #fff;
        padding: 0.9rem 0.95rem;
    }

    .vt-user-profile-page .vt-info-card h5 {
        margin: 0 0 0.55rem;
        font-size: 0.82rem;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .vt-user-profile-page .vt-info-row {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 0.45rem;
        align-items: start;
        padding: 0.28rem 0;
        border-bottom: 1px dashed #e6eef3;
    }

    .vt-user-profile-page .vt-info-row:last-child {
        border-bottom: 0;
    }

    .vt-user-profile-page .vt-info-label {
        color: #526477;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .vt-user-profile-page .vt-info-value {
        color: #0f172a;
        font-size: 0.82rem;
        font-weight: 600;
        word-break: break-word;
    }

    .vt-user-profile-page .vt-address-card {
        border: 1px solid var(--profile-border);
        border-radius: 12px;
        padding: 0.9rem 0.95rem;
        background: #fbfdff;
    }

    .vt-user-profile-page .vt-address-card h5 {
        margin: 0 0 0.45rem;
        font-size: 0.82rem;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .vt-user-profile-page .vt-address-card p {
        margin: 0;
        color: #334155;
        font-size: 0.84rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
    }

    @@media (max-width: 991.98px) {
        .vt-user-profile-page .vt-info-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .vt-user-profile-page .vt-profile-hero {
            padding: 1rem;
        }

        .vt-user-profile-page .vt-profile-body {
            padding: 0.95rem;
        }

        .vt-user-profile-page .vt-profile-title {
            font-size: 1.08rem;
        }

        .vt-user-profile-page .vt-info-row {
            grid-template-columns: 110px 1fr;
        }

        .vt-user-profile-page .vt-profile-actions .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="vt-project-page vt-user-profile-page">
    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card card--table-section vt-profile-shell">
                <div class="card-body">
                    <div class="vt-profile-hero">
                        <div class="vt-profile-main">
                            <div class="vt-profile-avatar">@initials</div>
                            <div>
                                <h1 class="vt-profile-title">@displayName</h1>
                                <p class="vt-profile-sub">Login: @userCode</p>
                                <div class="vt-profile-tags">
                                    <span class="vt-tag vt-tag-role">@roleLabel</span>
                                    <span class="vt-tag @(isActive ? "vt-tag-status-active" : "vt-tag-status-inactive")">@statusLabel</span>
                                </div>
                            </div>
                        </div>
                        <div class="vt-profile-actions">
                            <a href="/VT/Account/ChangePassword" class="btn btn-primary btn-sm">Change Password</a>
                            <a href="/VT/Home/Dashboard" class="btn btn-light btn-sm">Back To Dashboard</a>
                        </div>
                    </div>

                    <div class="vt-profile-body">
                        <div class="vt-info-grid">
                            <div class="vt-info-card">
                                <h5>Contact</h5>
                                <div class="vt-info-row">
                                    <span class="vt-info-label">Email</span>
                                    <span class="vt-info-value">@emailId</span>
                                </div>
                                <div class="vt-info-row">
                                    <span class="vt-info-label">Phone</span>
                                    <span class="vt-info-value">@contactNumber</span>
                                </div>
                            </div>

                            <div class="vt-info-card">
                                <h5>Account</h5>
                                <div class="vt-info-row">
                                    <span class="vt-info-label">Username</span>
                                    <span class="vt-info-value">@userCode</span>
                                </div>
                                <div class="vt-info-row">
                                    <span class="vt-info-label">Created</span>
                                    <span class="vt-info-value">@createdDate</span>
                                </div>
                                <div class="vt-info-row">
                                    <span class="vt-info-label">Ratings</span>
                                    <span class="vt-info-value">@rating</span>
                                </div>
                                <div class="vt-info-row">
                                    <span class="vt-info-label">Projects</span>
                                    <span class="vt-info-value">@projects</span>
                                </div>
                            </div>
                        </div>

                        <div class="vt-address-card">
                            <h5>Address</h5>
                            <div class="vt-info-row">
                                <span class="vt-info-label">Country</span>
                                <span class="vt-info-value">@country</span>
                            </div>
                            <p>@address</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
