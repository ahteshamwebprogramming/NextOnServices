@{
    ViewData["Title"] = "Generate Complete Redirects";
    Layout = "~/Areas/VT/Views/Shared/_Layout.cshtml";
}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="~/css/custmahte.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-project-page.css" rel="stylesheet" asp-append-version="true" />
<link href="~/css/VT/vt-dashboard-ref.css" rel="stylesheet" asp-append-version="true" />
<style>
    .vt-redirects .table-section-header { border-left-color: var(--vt-theme, #1d7874); }
    .vt-redirects .card--table-section { border-color: rgba(29, 120, 116, 0.25); box-shadow: 0 4px 16px rgba(29, 120, 116, 0.08); }
    .vt-redirects .redirect-lbl { background-color: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 8px; padding: 0.5rem 0.75rem; line-height: 1.6; font-size: 0.875rem; }
    .vt-redirects .redirect-link-item { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .vt-redirects .redirect-link-item .redirect-lbl { flex: 1; min-width: 200px; }
    .vt-redirects .redirect-link-item.strikethrough .redirect-lbl { text-decoration: line-through; color: #64748b; }
    .vt-redirects .redirect-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
    .vt-redirects .redirect-actions a { font-size: 0.8125rem; cursor: pointer; }
    #CharacterLength .modal-header { border-bottom-color: rgba(29, 120, 116, 0.25); }
    #CharacterLength .btn-primary { background: linear-gradient(135deg, #1d7874 0%, #165c59 100%); border-color: #165c59; }
</style>

<div class="vt-project-page vt-dashboard-ref vt-redirects">
    <div class="row">
        <div class="col-md-12 grid-margin stretch-card">
            <div class="card card--table-section">
                <div class="card-body">
                    <p class="table-section-header">Generate Complete Redirects</p>
                    <p class="card-description mb-3">Generate new complete redirect codes, save them, and manage or view deleted redirects.</p>

                    <div class="form-group">
                        <label class="control-label mb-2 font-weight-semibold">Completes</label>
                        <a href="javascript:void(0)" class="btn btn-primary btn-sm mb-2" id="btnOpenGenerateLink">Generate Link</a>
                        <div id="divCompleteRedirectLinks">
                            <ul class="list-unstyled mb-0" id="completeRedirectList"></ul>
                        </div>
                    </div>

                    <div class="form-group mt-4">
                        <label class="control-label mb-2 font-weight-semibold">Deleted Redirects</label>
                        <div id="divDeletedCompleteRedirectLinks">
                            <ul class="list-unstyled mb-0" id="deletedRedirectList"></ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="CharacterLength" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Generate Link</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <div id="div_GenerateLink">
                    <p>Please enter length (between 8 and 16 characters) of the code for Complete.</p>
                    <input type="text" id="txtChar" class="form-control form-control-sm" style="width: 50%; max-width: 120px;" maxlength="2" placeholder="8-16" />
                </div>
                <div id="div_CheckLink" style="display: none;">
                    <label class="small">URL:</label>
                    <div class="d-flex align-items-center flex-wrap gap-1">
                        <span class="small text-muted" id="baseUrlLabel"></span>
                        <input type="text" id="txtRandomCode" class="form-control form-control-sm" style="width: 120px;" />
                        <span class="small text-muted">&amp;RC=0</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" id="btnGenerateLink">Generate Link</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnSaveLink" style="display: none;">Save Link</button>
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal" id="CloseGenerateLink">Close</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var baseUrl = (window.location.origin || '') + '/VT/ProjectStatus.aspx?ID=[respondentID]&Status=';

            function resetPopup() {
                $('#div_GenerateLink').show();
                $('#div_CheckLink').hide();
                $('#btnGenerateLink').show();
                $('#btnSaveLink').hide();
                $('#txtChar').val('');
                $('#txtRandomCode').val('');
            }

            $('#txtChar').on('input paste keypress', function (evt) {
                var charCode = (evt.which) ? evt.which : evt.keyCode;
                if (charCode > 31 && (charCode < 48 || charCode > 57)) return false;
                return true;
            });

            $('#btnOpenGenerateLink').on('click', function () {
                resetPopup();
                $('#CharacterLength').modal('show');
            });

            $('#btnGenerateLink').on('click', function () {
                var charLimit = $('#txtChar').val();
                var num = parseInt(charLimit, 10);
                if (isNaN(num) || num < 8 || num > 16) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({ title: 'Error', text: 'Only integers between 8 and 16 are allowed.', icon: 'error', confirmButtonText: 'OK' });
                    } else { alert('Only integers between 8 and 16 are allowed.'); }
                    return;
                }
                $.ajax({
                    type: 'POST',
                    url: '/VT/Redirects/GenerateRandomLink',
                    contentType: 'application/json',
                    data: JSON.stringify({ Charl: charLimit }),
                    success: function (data) {
                        if (data === 'InvalidNumber101') {
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({ title: 'Error', text: 'Only integers between 8 and 16 are allowed.', icon: 'error', confirmButtonText: 'OK' });
                            } else { alert('Only integers between 8 and 16 are allowed.'); }
                            return;
                        }
                        if (data && data !== '') {
                            $('#div_GenerateLink').slideUp();
                            $('#div_CheckLink').slideDown();
                            $('#btnGenerateLink').hide();
                            $('#btnSaveLink').show();
                            $('#baseUrlLabel').text(baseUrl);
                            $('#txtRandomCode').val(data);
                        } else {
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({ title: 'Error', text: 'Entered value is not valid.', icon: 'error', confirmButtonText: 'OK' });
                            } else { alert('Entered value is not valid.'); }
                        }
                    },
                    error: function () { alert('An error occurred.'); }
                });
            });

            $('#btnSaveLink').on('click', function () {
                var code = $('#txtRandomCode').val();
                if (!code || $.trim(code) === '') {
                    alert('Cannot leave the code empty.');
                    return false;
                }
                var charLimit = $('#txtChar').val();
                if (charLimit && parseInt(charLimit, 10) !== code.length) {
                    alert('Code length does not match.');
                    return false;
                }
                if (!/^[a-zA-Z0-9]*$/.test(code)) {
                    alert('Your code contains illegal characters.');
                    return false;
                }
                $.ajax({
                    type: 'POST',
                    url: '/VT/Redirects/SaveCompleteLink',
                    contentType: 'application/json',
                    data: JSON.stringify({ Code: code, Link: baseUrl + code + '&RC=0' }),
                    success: function (data) {
                        if (data && data[0]) {
                            var ret = data[0].retVal !== undefined ? data[0].retVal : data[0].RetVal;
                            if (ret === 1) {
                                if (typeof Swal !== 'undefined') {
                                    Swal.fire({ title: 'Saved', text: 'Link saved successfully.', icon: 'success', confirmButtonText: 'OK' });
                                } else { alert('Saved successfully.'); }
                                FetchCompleteRedirects();
                                FetchDeletedRedirects();
                                $('#CharacterLength').modal('hide');
                            } else if (ret === -1) {
                                alert('This code already exists.');
                            } else if (ret === -2) {
                                alert('Cannot leave code empty.');
                            }
                        }
                    },
                    error: function () { alert('An error occurred.'); }
                });
            });

            $('#divCompleteRedirectLinks').on('click', '.redirect-disable', function () {
                var id = $(this).data('id');
                if (!id) return;
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        title: 'Are you sure?',
                        text: 'You want to disable this redirect?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#1d7874',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, disable it'
                    }).then(function (result) {
                        if (result.isConfirmed) updateStatus(id, 5);
                    });
                } else {
                    if (confirm('Disable this redirect?')) updateStatus(id, 5);
                }
            });
            $('#divCompleteRedirectLinks').on('click', '.redirect-enable', function () {
                var id = $(this).data('id');
                if (!id) return;
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        title: 'Are you sure?',
                        text: 'You want to enable this redirect?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#1d7874',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, enable it'
                    }).then(function (result) {
                        if (result.isConfirmed) updateStatus(id, 4);
                    });
                } else {
                    if (confirm('Enable this redirect?')) updateStatus(id, 4);
                }
            });
            $('#divCompleteRedirectLinks').on('click', '.redirect-delete', function () {
                var id = $(this).data('id');
                if (!id) return;
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        title: 'Are you sure?',
                        text: 'You want to delete this redirect?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: 'Yes, delete it'
                    }).then(function (result) {
                        if (result.isConfirmed) updateStatus(id, 3);
                    });
                } else {
                    if (confirm('Are you sure you want to delete this redirect?')) updateStatus(id, 3);
                }
            });

            FetchCompleteRedirects();
            FetchDeletedRedirects();
        });

        function getBaseUrl() {
            return (window.location.origin || '') + '/VT/ProjectStatus.aspx?ID=[respondentID]&Status=';
        }

        function FetchCompleteRedirects() {
            $.ajax({
                type: 'POST',
                url: '/VT/Redirects/FetchCompleteLink',
                contentType: 'application/json',
                data: JSON.stringify({ opt: 1 }),
                success: function (data) {
                    var baseUrl = getBaseUrl();
                    var html = '';
                    if (data && data.length > 0) {
                        for (var i = 0; i < data.length; i++) {
                            var item = data[i];
                            var code = item.code || item.Code || '';
                            var enable = item.enable !== undefined ? item.enable : item.Enable;
                            var id = item.id !== undefined ? item.id : item.Id;
                            var url = baseUrl + code + '&RC=0';
                            var strike = (enable === 0 || enable === '0') ? ' redirect-link-item strikethrough' : ' redirect-link-item';
                            html += '<li class="' + strike + '">';
                            html += '<label class="redirect-lbl">' + $('<div/>').text(url).html() + '</label>';
                            html += '<div class="redirect-actions">';
                            if (enable === 1 || enable === '1') {
                                html += '<a class="redirect-disable text-primary" data-id="' + id + '">Disable</a>';
                            } else {
                                html += '<a class="redirect-enable text-success" data-id="' + id + '">Enable</a>';
                            }
                            html += '<a class="redirect-delete text-danger" data-id="' + id + '">Delete</a>';
                            html += '</div></li>';
                        }
                    }
                    $('#completeRedirectList').html(html || '<li class="text-muted small">No complete redirect links yet. Use Generate Link to add one.</li>');
                },
                error: function () {
                    $('#completeRedirectList').html('<li class="text-danger small">Failed to load redirects.</li>');
                }
            });
        }

        function FetchDeletedRedirects() {
            $.ajax({
                type: 'POST',
                url: '/VT/Redirects/FetchCompleteLink',
                contentType: 'application/json',
                data: JSON.stringify({ opt: 6 }),
                success: function (data) {
                    var baseUrl = getBaseUrl();
                    var html = '';
                    if (data && data.length > 0) {
                        for (var i = 0; i < data.length; i++) {
                            var code = (data[i].code || data[i].Code || '');
                            var url = baseUrl + code + '&RC=0';
                            html += '<li class="redirect-link-item"><label class="redirect-lbl">' + $('<div/>').text(url).html() + '</label></li>';
                        }
                    }
                    $('#deletedRedirectList').html(html || '<li class="text-muted small">No deleted redirects.</li>');
                },
                error: function () {
                    $('#deletedRedirectList').html('<li class="text-danger small">Failed to load deleted redirects.</li>');
                }
            });
        }

        function updateStatus(id, opt) {
            $.ajax({
                type: 'POST',
                url: '/VT/Redirects/UpdateStatusCompleteLink',
                contentType: 'application/json',
                data: JSON.stringify({ opt: opt, Id: id }),
                success: function (data) {
                    if (data && data[0]) {
                        var ret = data[0].retVal !== undefined ? data[0].retVal : data[0].RetVal;
                        if (ret === 1) {
                            FetchCompleteRedirects();
                            FetchDeletedRedirects();
                        }
                    }
                }
            });
        }
    </script>
}
